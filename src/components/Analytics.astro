<!-- GALAXY EVENT ENGINE -->
<script is:inline>
    /**
     * trackLead: Captures high-intent conversion events across all pixels.
     */
    window.trackLead = function(data = {}) {
        console.log('🚀 ExpatBuildr: Tracking Lead Event', data);

        if (window.gtag) {
            gtag('event', 'generate_lead', {
                "event_label": data.label || "Newsletter Signup",
                "value": data.value || 0
            });
        }
        if (window.fbq) {
            fbq('track', 'Lead');
        }
        if (window.ttq) {
            ttq.track('CompletePayment', { value: data.value || 50.00, currency: 'USD' });
        }
        if (window.rdt) {
            rdt('track', 'Lead');
        }
        if (window.lintrk) {
            window.lintrk('track', { conversion_id: 1234567 });
        }
        if (window.twq) {
            twq('event', 'Lead', {});
        }
    };

    /**
     * initAdvancedMatching: Helper to initialize Advanced Matching
     */
    window.initAdvancedMatching = function(email) {
        if (!email) return;
        console.log('🔒 ExpatBuildr: Initializing Advanced Matching');
        if (window.rdt) {
            rdt('init', 'a2_iwih8dctksoi', { "email": email });
        }
        if (window.fbq) {
            fbq('init', '1480646753745240', { em: email });
        }
    };
</script>
