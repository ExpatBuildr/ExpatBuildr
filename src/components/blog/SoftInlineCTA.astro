---
interface Props {
	gatePosition?: number;
}

const { gatePosition = 0.6 } = Astro.props;
const id = `soft-cta-${Math.random().toString(36).slice(2, 8)}`;

const html = await Astro.slots.render('default');
const splitTarget = Math.floor(html.length * gatePosition);
const closingTag = '</p>';
let splitIndex = html.indexOf(closingTag, splitTarget);
if (splitIndex === -1) {
    splitIndex = splitTarget;
} else {
    splitIndex += closingTag.length;
}

const firstHalf = html.slice(0, splitIndex);
const secondHalf = html.slice(splitIndex);
---

<div class="prose prose-invert max-w-none" set:html={firstHalf} />

<div class="soft-inline-cta relative my-14 rounded-[2rem] border border-accent-blue/30 bg-accent-blue/[0.04] dark:bg-accent-blue/[0.06] p-8 md:p-10" id={id}>
    <button
        type="button"
        class="soft-cta-dismiss absolute top-4 right-4 text-slate-400 hover:text-slate-700 dark:hover:text-white transition-colors"
        aria-label="Dismiss"
    >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6L6 18"/><path d="M6 6l12 12"/></svg>
    </button>

    <div class="flex flex-col sm:flex-row gap-6 items-start sm:items-center">
        <div class="flex-1">
            <p class="text-xs font-bold uppercase tracking-[0.2em] text-accent-blue mb-2">
                Galaxy Arbitrage Newsletter — <span class="soft-cta-count">65+</span> founders and growing
            </p>
            <p class="text-slate-700 dark:text-slate-300 text-base md:text-lg leading-relaxed">
                One weekly email on geo-arbitrage, remote income systems, and the expat founder playbook — no fluff, just what's working. Recent issue: the exact bank setup that avoided a frozen wire transfer between three countries.
            </p>
        </div>

        <form class="soft-cta-form flex flex-col sm:flex-row gap-3 w-full sm:w-auto shrink-0" data-cta-id={id}>
            <input
                type="email"
                required
                placeholder="you@email.com"
                class="soft-cta-email px-5 py-3 rounded-xl bg-white dark:bg-galaxy-900/80 border border-slate-200 dark:border-white/10 text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-accent-blue/50 focus:border-accent-blue transition-all text-sm min-w-[220px]"
            />
            <button
                type="submit"
                class="soft-cta-submit px-6 py-3 rounded-xl bg-accent-blue text-white dark:text-galaxy-950 font-bold uppercase tracking-wide text-sm hover:bg-slate-900 dark:hover:bg-white hover:scale-[1.02] active:scale-95 transition-all whitespace-nowrap"
            >
                Subscribe Free
            </button>
        </form>
    </div>

    <p class="soft-cta-status hidden text-sm mt-4 font-medium"></p>
</div>

<div class="prose prose-invert max-w-none" set:html={secondHalf} />

<script>
    document.querySelectorAll<HTMLFormElement>('.soft-cta-form').forEach((form) => {
        const wrapper = form.closest('.soft-inline-cta');
        const status = wrapper?.querySelector('.soft-cta-status') as HTMLElement | null;
        const submitBtn = form.querySelector('.soft-cta-submit') as HTMLButtonElement;

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            const emailInput = form.querySelector('.soft-cta-email') as HTMLInputElement;
            const email = emailInput.value;

            submitBtn.disabled = true;
            submitBtn.textContent = 'Joining...';

            try {
                const response = await fetch('/api/subscribe', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        email,
                        tags: ['soft_inline_cta', 'founder'],
                        utm_medium: 'soft-inline-cta'
                    })
                });

                const result = await response.json();

                if (response.ok && result.success) {
                    form.classList.add('hidden');
                    if (status) {
                        status.textContent = "You're in — check your inbox to confirm.";
                        status.classList.remove('hidden');
                        status.classList.add('text-emerald-600', 'dark:text-emerald-400');
                    }
                } else {
                    throw new Error(result.error || 'Subscription failed');
                }
            } catch (err) {
                submitBtn.disabled = false;
                submitBtn.textContent = 'Subscribe Free';
                if (status) {
                    status.textContent = 'Something went wrong — try again.';
                    status.classList.remove('hidden');
                    status.classList.add('text-rose-500');
                }
            }
        });
    });

    document.querySelectorAll('.soft-cta-dismiss').forEach((btn) => {
        btn.addEventListener('click', () => {
            const card = btn.closest('.soft-inline-cta') as HTMLElement;
            if (card) {
                card.style.transition = 'opacity 0.3s ease, max-height 0.4s ease';
                card.style.opacity = '0';
                card.style.maxHeight = card.scrollHeight + 'px';
                requestAnimationFrame(() => { card.style.maxHeight = '0px'; card.style.overflow = 'hidden'; card.style.marginTop = '0'; card.style.marginBottom = '0'; card.style.padding = '0'; });
                setTimeout(() => card.remove(), 450);
            }
        });
    });

    fetch('/get-counter')
        .then(res => res.json())
        .then(data => {
            if (data?.count) {
                document.querySelectorAll('.soft-cta-count').forEach(el => {
                    el.textContent = `${data.count}+`;
                });
            }
        })
        .catch(() => {});
</script>
