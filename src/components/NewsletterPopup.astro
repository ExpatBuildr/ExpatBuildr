---
interface Props {
  trigger: 'delay' | 'inactivity';
  delayMs?: number;    // for trigger='delay' (homepage)
  inactivityMs?: number; // for trigger='inactivity' (blog)
}
const { trigger, delayMs = 8000, inactivityMs = 40000 } = Astro.props;
---

<!-- Newsletter Popup Overlay -->
<div
  id="nl-popup-overlay"
  class="fixed inset-0 z-[9999] bg-black/60 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300 flex items-center justify-center px-4"
>
  <div
    id="nl-popup-card"
    class="relative max-w-md w-full rounded-[2rem] border border-slate-200 dark:border-white/15 bg-white dark:bg-[#2d2d2d] shadow-[0_0_80px_rgba(100,100,100,0.15)] p-8 md:p-10 text-center scale-95 transition-transform duration-300"
  >
    <!-- Close -->
    <button
      id="nl-popup-close"
      class="absolute top-4 right-4 text-slate-400 dark:text-slate-500 hover:text-slate-900 dark:hover:text-white transition-colors p-1"
      aria-label="Close"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
    </button>

    <!-- Icon -->
    <div class="inline-flex p-3 rounded-2xl mb-5" style="background: rgba(0,229,160,0.1); border: 1px solid rgba(0,229,160,0.2);">
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#00e5a0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
    </div>

    <p class="text-[10px] font-mono uppercase tracking-[0.25em] text-gradient mb-3">Free Weekly Intel</p>
    <h2 class="text-2xl md:text-3xl font-black font-display text-slate-900 dark:text-white uppercase tracking-tighter leading-tight mb-3">
      Get the Arbitrage<br/><span class="text-gradient">Edge Every Week</span>
    </h2>
    <p class="text-slate-600 dark:text-slate-400 text-sm mb-6 max-w-xs mx-auto">
      Geographic arbitrage plays, remote income systems, and AI tools. Free. Plus 4 resources on signup.
    </p>

    <!-- Form -->
    <div id="nl-popup-form-wrap">
      <form id="nl-popup-form" class="flex flex-col gap-3">
        <input
          type="email"
          id="nl-popup-email"
          placeholder="Enter your best email"
          required
          class="w-full px-5 py-3.5 rounded-xl bg-slate-100 dark:bg-white/5 border border-slate-200 dark:border-white/10 text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-slate-500 focus:outline-none focus:ring-2 focus:border-accent-cyan/40 transition-all font-inter text-sm"
          style="focus-ring-color: #00e5a0;"
        />
        <button
          type="submit"
          id="nl-popup-submit"
          class="w-full py-3.5 rounded-xl font-display font-black uppercase tracking-wider text-white text-sm transition-all hover:scale-[1.02] active:scale-95"
          style="background: linear-gradient(135deg, #0ea5e9, #a855f7, #ec4899);"
        >
          Join Free →
        </button>
      </form>
      <p class="mt-3 text-[10px] text-slate-500 font-mono uppercase tracking-widest">✓ Weekly Intel · ✓ 4 Free Resources · ✓ No Spam</p>
    </div>

    <!-- Success state -->
    <div id="nl-popup-success" class="hidden flex flex-col items-center gap-3">
      <div class="w-14 h-14 rounded-full flex items-center justify-center" style="background: rgba(16,185,129,0.15); border: 1px solid rgba(16,185,129,0.3);">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
      </div>
      <p class="text-slate-900 dark:text-white font-bold text-lg uppercase tracking-tight">Check Your Inbox</p>
      <div class="bg-slate-100 dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-xl px-5 py-3 text-center">
        <p class="text-slate-600 dark:text-slate-300 text-sm font-mono">Reply <span class="font-bold text-accent-cyan">hi</span> to confirm your email</p>
        <p class="text-slate-500 dark:text-slate-500 text-[11px] mt-1">Keeps us out of your promotions tab</p>
      </div>
    </div>

    <!-- Error -->
    <p id="nl-popup-error" class="hidden text-rose-400 text-xs font-mono mt-3 uppercase tracking-widest">Something went wrong. Try again.</p>
  </div>
</div>

<script define:vars={{ trigger, delayMs, inactivityMs }}>
  const COOKIE_JOINED = 'gb_newsletter_joined';

  function hasCookie(name) {
    return document.cookie.split('; ').some(c => c.startsWith(name + '='));
  }

  function setCookie(name, days) {
    const d = new Date();
    d.setDate(d.getDate() + days);
    document.cookie = `${name}=1; expires=${d.toUTCString()}; path=/; SameSite=Lax`;
  }

  // Don't show if already subscribed
  if (hasCookie(COOKIE_JOINED)) {
    // noop — leave hidden
  } else {
    const overlay = document.getElementById('nl-popup-overlay');
    const card = document.getElementById('nl-popup-card');
    const closeBtn = document.getElementById('nl-popup-close');
    const form = document.getElementById('nl-popup-form');
    const formWrap = document.getElementById('nl-popup-form-wrap');
    const success = document.getElementById('nl-popup-success');
    const errorEl = document.getElementById('nl-popup-error');
    const submitBtn = document.getElementById('nl-popup-submit');
    const emailInput = document.getElementById('nl-popup-email');

    function showPopup() {
      if (!overlay) return;
      overlay.classList.remove('opacity-0', 'pointer-events-none');
      overlay.classList.add('opacity-100');
      card?.classList.remove('scale-95');
      card?.classList.add('scale-100');
    }

    function dismissPopup() {
      overlay?.classList.add('opacity-0', 'pointer-events-none');
      overlay?.classList.remove('opacity-100');
    }

    // Dismiss on close button or overlay click
    closeBtn?.addEventListener('click', dismissPopup);
    overlay?.addEventListener('click', (e) => {
      if (e.target === overlay) dismissPopup();
    });

    // Form submission
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = emailInput.value;
      submitBtn.disabled = true;
      submitBtn.textContent = 'Joining...';
      errorEl?.classList.add('hidden');

      try {
        const res = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, tags: ['popup_subscribe', 'founder'], utm_medium: 'popup' })
        });
        const data = await res.json();

        if (res.ok && data.ok) {
          setCookie(COOKIE_JOINED, 30);
          setCookie('gb_subscribed', 30);
          formWrap?.classList.add('hidden');
          success?.classList.remove('hidden');
          success?.classList.add('flex');
          setTimeout(dismissPopup, 3500);
        } else {
          throw new Error('failed');
        }
      } catch {
        errorEl?.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Join Free →';
      }
    });

    // Trigger logic
    if (trigger === 'delay') {
      setTimeout(showPopup, delayMs);
    } else if (trigger === 'inactivity') {
      let timer;
      const reset = () => {
        clearTimeout(timer);
        timer = setTimeout(showPopup, inactivityMs);
      };
      ['mousemove', 'scroll', 'keydown', 'touchstart'].forEach(ev =>
        document.addEventListener(ev, reset, { passive: true })
      );
      // Start the timer on load
      reset();
    }
  }
</script>
