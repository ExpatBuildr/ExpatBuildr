---
interface Props {
  persona: string;
  magnet: string;
}
const { persona, magnet } = Astro.props;
const metaPixelId = import.meta.env.META_PIXEL_ID;
const gtagId = import.meta.env.GTAG_ID;
---

{metaPixelId && (
  <>
    <script is:inline define:vars={{ metaPixelId, persona, magnet }}>
      !function(f,b,e,v,n,t,s)
      {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
      n.callMethod.apply(n,arguments):n.queue.push(arguments)};
      if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
      n.queue=[];t=b.createElement(e);t.async=!0;
      t.src=v;s=b.getElementsByTagName(e)[0];
      s.parentNode.insertBefore(t,s)}(window,document,'script',
      'https://connect.facebook.net/en_US/fbevents.js');
      fbq('init', metaPixelId);
      fbq('track', 'PageView');
      fbq('track', 'ViewContent', {
        content_name: persona,
        content_category: 'Persona Landing',
      });
      fbq('trackCustom', 'PersonaPageView', { persona, magnet });
    </script>
    <noscript>
      <img height="1" width="1" style="display:none"
        src={`https://www.facebook.com/tr?id=${metaPixelId}&ev=PageView&noscript=1`} />
    </noscript>
  </>
)}

{gtagId && (
  <>
    <script is:inline define:vars={{ gtagId }} async src={`https://www.googletagmanager.com/gtag/js?id=${gtagId}`}></script>
    <script is:inline define:vars={{ gtagId, persona }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', gtagId);
      gtag('event', 'persona_page_view', { persona });
    </script>
  </>
)}
