---
import Pixels from '../components/GalaxyPixels.astro';
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
<title>You're in — Your Download is Starting</title>
<meta name="robots" content="noindex, nofollow">
<Pixels page="thank-you-friction" magnet="philippines-arbitrage-playbook" source="playbook" />
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }
:root {
  --ink:#111118; --ink-soft:#444455; --ink-mute:#8888AA;
  --white:#FFFFFF; --cream:#FAFAF7; --amber:#F59E0B;
  --amber-lt:#FEF3C7; --amber-dk:#B45309; --border:#E8E8F0;
  --green:#16A34A; --green-lt:#DCFCE7;
}
body { font-family:'Inter',sans-serif; background:var(--white); color:var(--ink); line-height:1.6; min-height:100vh; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:40px 24px; text-align:center; }

.ty-logo { font-family:'Syne',sans-serif; font-weight:800; font-size:15px; color:var(--ink-mute); margin-bottom:40px; display:flex; align-items:center; gap:6px; justify-content:center; text-decoration:none; }
.ty-logo-img { width:24px; height:24px; border-radius:50%; object-fit:cover; }
.logo-dot { width:7px; height:7px; border-radius:50%; background:var(--amber); display:inline-block; }

.ty-check { width:72px; height:72px; border-radius:50%; background:var(--green-lt); border:3px solid var(--green); display:flex; align-items:center; justify-content:center; font-size:32px; margin:0 auto 24px; }

h1 { font-family:'Syne',sans-serif; font-size:clamp(24px,4vw,38px); font-weight:800; line-height:1.1; margin-bottom:12px; letter-spacing:-.02em; }
h1 span { color:var(--green); }

.ty-sub { font-size:16px; color:var(--ink-soft); max-width:460px; margin:0 auto 36px; line-height:1.6; }

.ty-redirect-box { background:var(--amber-lt); border:1px solid var(--amber); border-radius:16px; padding:28px 32px; max-width:440px; margin:0 auto 28px; }
.ty-redirect-box .label { font-size:12px; font-weight:700; letter-spacing:.08em; text-transform:uppercase; color:var(--amber-dk); margin-bottom:8px; }
.ty-redirect-box strong { font-family:'Syne',sans-serif; font-size:20px; color:var(--ink); display:block; margin-bottom:6px; }
.ty-redirect-box p { font-size:13px; color:var(--ink-soft); line-height:1.5; }
.ty-redirect-box a { color:var(--amber-dk); font-weight:600; }

.ty-countdown { font-size:14px; color:var(--ink-mute); margin-bottom:20px; }
.ty-countdown span { font-family:'Syne',sans-serif; font-weight:700; font-size:20px; color:var(--amber-dk); }

.btn-skip { background:var(--ink); color:var(--white); border:none; border-radius:10px; padding:14px 32px; font-size:15px; font-weight:700; cursor:pointer; font-family:'Syne',sans-serif; transition:background .15s; text-decoration:none; display:inline-block; }
.btn-skip:hover { background:var(--amber); color:var(--ink); }

.ty-divider { width:100%; max-width:440px; border:none; border-top:1px solid var(--border); margin:36px auto; }

.what-next { max-width:440px; margin:0 auto; text-align:left; }
.what-next h3 { font-family:'Syne',sans-serif; font-size:15px; font-weight:700; margin-bottom:14px; text-align:center; color:var(--ink-soft); }
.next-item { display:flex; align-items:flex-start; gap:12px; margin-bottom:12px; }
.next-num { width:24px; height:24px; border-radius:50%; background:var(--amber-lt); color:var(--amber-dk); font-size:12px; font-weight:700; display:flex; align-items:center; justify-content:center; flex-shrink:0; margin-top:1px; }
.next-text { font-size:14px; color:var(--ink-soft); line-height:1.5; }
.next-text strong { color:var(--ink); }
</style>
</head>
<body>

<a href="https://expatbuildr.com" class="ty-logo"><img src="/logo.jpg" alt="ExpatBuildr" class="ty-logo-img">ExpatBuildr</a>

<div class="ty-check">⬇️</div>

<h1>Your download is starting —<br><span>it's on its way</span></h1>

<p class="ty-sub">The Philippines Arbitrage Playbook is downloading now. Once it lands — there's one thing that takes everything in the playbook from theory to a real working system.</p>

<div class="ty-redirect-box">
  <div class="label">⬇️ Downloading now</div>
  <strong>Philippines Arbitrage Playbook</strong>
  <p>Your PDF is downloading automatically. If it does not start in a few seconds, <a href="https://galaxyarbitrage.com/downloads/philippines-arbitrage-playbook.pdf" target="_blank" rel="noopener">click here to download manually.</a></p>
</div>

<p class="ty-countdown">Taking you to the full toolkit in <span id="countdown">7</span> seconds — or</p>

<a href="/kit" class="btn-skip">See the Kit Now →</a>

<hr class="ty-divider">

<div class="what-next">
  <h3>While it downloads</h3>
  <div class="next-item">
    <div class="next-num">1</div>
    <div class="next-text"><strong>Check your spam folder</strong> if you don't see a welcome email in 5 minutes. Add galaxyarbitrage@mail.beehiiv.com to your contacts to keep future issues out of spam.</div>
  </div>
  <div class="next-item">
    <div class="next-num">2</div>
    <div class="next-text"><strong>Reply "Hi" to the welcome email.</strong> It tells your email provider this is real mail from a real person — keeps future issues landing in Primary.</div>
  </div>
  <div class="next-item">
    <div class="next-num">3</div>
    <div class="next-text"><strong>Follow @expatbuildr on X and Instagram</strong> for the daily build-in-public posts between newsletter issues.</div>
  </div>
</div>

<script>
// Auto-trigger download on page load
window.addEventListener('load', () => {
  const link = document.createElement('a');
  link.href = 'https://galaxyarbitrage.com/downloads/philippines-arbitrage-playbook.pdf';
  link.target = '_blank';
  link.rel = 'noopener';
  document.body.appendChild(link);
  link.click();
  document.body.removeChild(link);
});

// 7 second countdown then redirect to /kit
let count = 7;
const el = document.getElementById('countdown');
const timer = setInterval(() => {
  count--;
  if (el) el.textContent = count;
  if (count <= 0) {
    clearInterval(timer);
    window.location.href = '/kit';
  }
}, 1000);
</script>
</body>
</html>
