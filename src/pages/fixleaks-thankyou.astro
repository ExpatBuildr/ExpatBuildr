      <a href="https://x.com/expatbuildr" target="_blank" rel="noopener" class="footer-link">X</a>
    </nav>
  </footer>

  <script define:vars={{ PACKAGES }}>
    const params = new URLSearchParams(window.location.search);
    const pkg = params.get('package');
    const price = params.get('price');

    const matched = pkg
      ? Object.values(PACKAGES).find(p => p.name.toLowerCase() === pkg.toLowerCase())
      : null;

    if (pkg) {
      const sub = document.querySelector('.confirm-sub');
      if (sub) {
        sub.innerHTML = `<strong>Your ${pkg}${price ? ` ($${price})` : ''} package is officially underway.</strong> That's not a form-letter response — I saw the payment hit and I'm already thinking through your build. You made the right call.`;
      }
    }

    if (matched?.delivery) {
      const deliveryValue = document.getElementById('deliveryValue');
      const deliveryTime = document.getElementById('deliveryTime');
      if (deliveryValue) deliveryValue.textContent = matched.delivery;
      if (deliveryTime) deliveryTime.textContent = `Within ${matched.delivery}`;
    }

    if (window.fbq) {
      fbq('track', 'Purchase', { currency: 'USD', value: price ? parseFloat(price.replace(/,/g, '')) : 0, content_name: pkg || 'ExpatBuildr Package' });
    }

    const toggleBtn = document.getElementById('themeToggle');
    if (toggleBtn) {
      const syncIcon = () => {
        toggleBtn.textContent = document.documentElement.classList.contains('dark') ? '☀️' : '🌙';
      };
      syncIcon();
      toggleBtn.addEventListener('click', () => {
        document.documentElement.classList.toggle('dark');
        const isDark = document.documentElement.classList.contains('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
        syncIcon();
      });
    }
  </script>

</body>
