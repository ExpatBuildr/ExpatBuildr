---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import { ArrowRight, Clock, BookOpen, TrendingUp, Zap } from 'lucide-astro';
---

<Layout
  title="Time Arbitrage Resources: Systems, Tools and Guides | ExpatBuildr"
  description="Everything in the Time Arbitrage pillar in one place — automation systems, SOP frameworks, virtual team hiring guides, and the weekly newsletter for expat founders."
  canonicalUrl="https://expatbuildr.com/blog/time-arbitrage-links"
  ogImage="/images/blog/pillars/time-arbitrage-hub.png"
>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Hero -->
    <div class="text-center mb-20">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-orange-500/10 border border-orange-500/20 text-orange-400 text-xs uppercase tracking-[0.2em] font-mono mb-8">
        <Clock size={12} /> Time Arbitrage
      </div>
      <h1 class="text-5xl md:text-7xl font-black font-display tracking-tighter text-slate-900 dark:text-white mb-6 uppercase leading-none">
        EVERYTHING<br /><span class="text-orange-400">TIME ARBITRAGE.</span>
      </h1>
      <p class="text-xl text-slate-600 dark:text-slate-400 max-w-2xl mx-auto font-inter leading-relaxed mb-8">
        Every tool, resource, and guide in the Time Arbitrage pillar — in one place. Build async systems, document your business, and delegate without losing quality.
      </p>
    </div>

    <!-- Featured Service -->
    <div class="mb-12">
      <div class="glass-card rounded-2xl p-8 border border-orange-500/30 bg-orange-500/5">
        <div class="flex flex-col md:flex-row md:items-center gap-6">
          <div class="shrink-0 w-16 h-16 rounded-2xl bg-orange-500/10 flex items-center justify-center">
            <TrendingUp class="text-orange-400" size={28} />
          </div>
          <div class="flex-1">
            <div class="text-xs font-mono uppercase tracking-wider text-orange-400 font-semibold mb-2">Featured Service</div>
            <h2 class="text-2xl font-black font-display uppercase tracking-tight text-slate-900 dark:text-white mb-2">Automation Systems</h2>
            <p class="text-slate-600 dark:text-slate-400 leading-relaxed mb-4">Done-for-you automation and SOP infrastructure that lets your business run without you constantly present.</p>
            <a href="/automation-systems/automate" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-orange-500 text-white font-bold text-sm hover:bg-orange-400 transition-all">
              See How It Works <ArrowRight size={16} />
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Services -->
    <div class="mb-16">
      <div class="flex items-center gap-3 mb-8">
        <TrendingUp class="text-orange-400" size={20} />
        <h2 class="text-2xl font-black font-display uppercase tracking-tight text-slate-900 dark:text-white">Done-For-You Services</h2>
        <div class="h-px flex-1 bg-slate-200 dark:bg-white/10"></div>
      </div>

      <div class="glass-card rounded-2xl p-8 border border-slate-200 dark:border-white/10 hover:border-orange-500/40 transition-all">
        <div class="flex flex-col md:flex-row md:items-center gap-6">
          <div class="flex-1">
            <div class="text-xs font-mono uppercase tracking-wider text-orange-400 font-semibold mb-2">Automation Service</div>
            <h3 class="text-xl font-black text-slate-900 dark:text-white mb-2">Async Operations Buildout</h3>
            <p class="text-slate-600 dark:text-slate-400 leading-relaxed mb-4">We map your workflows, document the SOPs, and build the automation and delegation stack so the business runs whether or not you're online.</p>
            <a href="/automation-systems/automation" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-orange-500/10 text-orange-400 font-bold text-sm hover:bg-orange-500/20 transition-all">
              Learn More <ArrowRight size={14} />
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Recommended Tools -->
    <div class="mb-16">
      <div class="flex items-center gap-3 mb-8">
        <Zap class="text-orange-400" size={20} />
        <h2 class="text-2xl font-black font-display uppercase tracking-tight text-slate-900 dark:text-white">Recommended Tools</h2>
        <div class="h-px flex-1 bg-slate-200 dark:bg-white/10"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="p-5 rounded-xl border border-slate-200 dark:border-white/10 hover:border-orange-500/40 transition-all">
          <h3 class="text-sm font-black text-slate-900 dark:text-white mb-1">Claude</h3>
          <p class="text-xs text-slate-500 dark:text-slate-400 leading-relaxed">Research, writing, code, strategy — the AI assistant used daily in this operation. claude.ai</p>
        </div>
        <div class="p-5 rounded-xl border border-slate-200 dark:border-white/10 hover:border-orange-500/40 transition-all">
          <h3 class="text-sm font-black text-slate-900 dark:text-white mb-1">ChatGPT</h3>
          <p class="text-xs text-slate-500 dark:text-slate-400 leading-relaxed">The most versatile AI assistant for content creation, research, and prompt-based workflows. chat.openai.com</p>
        </div>
        <div class="p-5 rounded-xl border border-slate-200 dark:border-white/10 hover:border-orange-500/40 transition-all">
          <h3 class="text-sm font-black text-slate-900 dark:text-white mb-1">Make.com</h3>
          <p class="text-xs text-slate-500 dark:text-slate-400 leading-relaxed">Automate repetitive workflows without code. Connects your tools so they work while you sleep.</p>
        </div>
        <div class="p-5 rounded-xl border border-slate-200 dark:border-white/10 hover:border-orange-500/40 transition-all">
          <h3 class="text-sm font-black text-slate-900 dark:text-white mb-1">Notion</h3>
          <p class="text-xs text-slate-500 dark:text-slate-400 leading-relaxed">Document everything. Build your operating system. The async communication hub for solo founders.</p>
        </div>
        <div class="p-5 rounded-xl border border-slate-200 dark:border-white/10 hover:border-orange-500/40 transition-all">
          <h3 class="text-sm font-black text-slate-900 dark:text-white mb-1">Loom</h3>
          <p class="text-xs text-slate-500 dark:text-slate-400 leading-relaxed">Record your screen and explain anything in minutes. Faster than writing. Clearer than text.</p>
        </div>
        <div class="p-5 rounded-xl border border-slate-200 dark:border-white/10 hover:border-orange-500/40 transition-all">
          <h3 class="text-sm font-black text-slate-900 dark:text-white mb-1">beehiiv</h3>
          <p class="text-xs text-slate-500 dark:text-slate-400 leading-relaxed">Build and monetize an audience that compounds over time. The newsletter platform behind Galaxy Arbitrage Weekly.</p>
        </div>
      </div>
    </div>

    <!-- Content Library -->
    <div class="mb-16">
      <div class="flex items-center gap-3 mb-8">
        <BookOpen class="text-orange-400" size={20} />
        <h2 class="text-2xl font-black font-display uppercase tracking-tight text-slate-900 dark:text-white">Content Library</h2>
        <div class="h-px flex-1 bg-slate-200 dark:bg-white/10"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="p-4 rounded-xl border border-slate-200 dark:border-white/10 hover:border-orange-500/40 transition-all">
          <ul class="space-y-2">
            <li><a href="/blog/time-arbitrage/what-is-time-arbitrage" class="text-sm text-slate-700 dark:text-slate-300 hover:text-orange-400 transition-colors">What Is Time Arbitrage and Why It Changes Everything for Founders</a></li>
            <li><a href="/blog/time-arbitrage/how-to-build-async-business-runs-without-you" class="text-sm text-slate-700 dark:text-slate-300 hover:text-orange-400 transition-colors">How to Build an Async Business That Runs Without You</a></li>
            <li><a href="/blog/time-arbitrage/founder-sop-stack" class="text-sm text-slate-700 dark:text-slate-300 hover:text-orange-400 transition-colors">The Founder SOP Stack: How to Document Everything So Anyone Can Run It</a></li>
            <li><a href="/blog/time-arbitrage/time-zone-competitive-advantage" class="text-sm text-slate-700 dark:text-slate-300 hover:text-orange-400 transition-colors">How to Use Time Zone Differences as a Competitive Advantage</a></li>
            <li><a href="/blog/time-arbitrage/hiring-first-virtual-assistant-expat-founder" class="text-sm text-slate-700 dark:text-slate-300 hover:text-orange-400 transition-colors">Hiring Your First Virtual Assistant as an Expat Founder</a></li>
          </ul>
        </div>
        <div class="p-4 rounded-xl border border-slate-200 dark:border-white/10 hover:border-orange-500/40 transition-all">
          <ul class="space-y-2">
            <li><a href="/blog/time-arbitrage/founder-delegation-framework" class="text-sm text-slate-700 dark:text-slate-300 hover:text-orange-400 transition-colors">The Complete Founder Delegation Framework: What to Keep, What to Hand Off</a></li>
            <li><a href="/blog/time-arbitrage/one-person-agency-team-of-three" class="text-sm text-slate-700 dark:text-slate-300 hover:text-orange-400 transition-colors">How to Run a One-Person Agency With a Team of Three</a></li>
            <li><a href="/blog/time-arbitrage/revenue-generating-system-works-while-you-sleep" class="text-sm text-slate-700 dark:text-slate-300 hover:text-orange-400 transition-colors">How to Build a Revenue-Generating System That Works While You Sleep</a></li>
            <li><a href="/blog/time-arbitrage/train-virtual-assistant-think-like-you" class="text-sm text-slate-700 dark:text-slate-300 hover:text-orange-400 transition-colors">How to Train a Virtual Assistant to Think Like You</a></li>
            <li><a href="/blog/ai-arbitrage/expat-founder-ai-stack" class="text-sm text-slate-700 dark:text-slate-300 hover:text-orange-400 transition-colors">The Expat Founder AI Stack: Tools That Replace an Entire Team</a></li>
          </ul>
        </div>
      </div>

      <div class="mt-6 text-center">
        <a href="/blog/time-arbitrage" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl border border-slate-200 dark:border-white/10 text-slate-700 dark:text-slate-300 font-semibold text-sm hover:border-orange-500/40 transition-all">
          View All Time Arbitrage Guides <ArrowRight size={16} />
        </a>
      </div>
    </div>

    <!-- Newsletter CTA -->
    <div class="rounded-2xl border border-orange-500/20 bg-orange-500/5 p-10 text-center mb-12">
      <h2 class="text-2xl font-black font-display uppercase tracking-tight text-slate-900 dark:text-white mb-3">Get the Weekly Time Arbitrage Intel</h2>
      <p class="text-slate-600 dark:text-slate-400 mb-6 max-w-lg mx-auto">Automation systems, SOP frameworks, and delegation strategies — every week, free.</p>
      <a href="/newsletter" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl bg-orange-500 text-white font-bold hover:bg-orange-400 transition-all">
        Join Free <ArrowRight size={16} />
      </a>
    </div>

  </div>
</Layout>
