---
export const prerender = true;
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { ArrowRight, Clock, TrendingUp, Globe, BookOpen, Zap } from 'lucide-astro';

const allPosts = await getCollection('blog', ({ data }) => {
  return import.meta.env.PROD ? data.draft !== true && data.archived !== true : true;
});

const posts = allPosts
  .filter(p => p.data.pillarId === 'time-arbitrage' && p.data.category !== 'Pillar Hub')
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric', year: 'numeric' }).format(date);

const calcReadTime = (body: string) => Math.max(1, Math.ceil(body.trim().split(/\s+/).length / 220));
---

<Layout
  title="Time Arbitrage: How Expat Founders Multiply Output Without More Hours | ExpatBuildr"
  description="Time arbitrage guides for expat founders — async systems, SOPs, delegation frameworks, and how to turn timezone differences into a competitive advantage."
  canonicalUrl="https://expatbuildr.com/blog/time-arbitrage"
  ogImage="/images/blog/pillars/time-arbitrage-hub.png"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "Time Arbitrage Hub | ExpatBuildr",
    "description": "Async systems, SOPs, delegation frameworks, and timezone leverage guides for expat founders.",
    "url": "https://expatbuildr.com/blog/time-arbitrage",
    "publisher": {
      "@type": "Organization",
      "name": "ExpatBuildr",
      "url": "https://expatbuildr.com"
    },
    "hasPart": posts.map(p => ({
      "@type": "BlogPosting",
      "headline": p.data.title,
      "url": `https://expatbuildr.com/blog/${p.id.replace(/\.mdx?$/, '')}`,
      "datePublished": p.data.pubDate.toISOString()
    }))
  })} />

  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Hero -->
    <div class="text-center mb-20">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-orange-500/10 border border-orange-500/20 text-orange-400 text-xs uppercase tracking-[0.2em] font-mono mb-8">
        <Clock size={12} /> Time Arbitrage
      </div>
      <h1 class="text-5xl md:text-7xl font-black font-display tracking-tighter text-slate-900 dark:text-white mb-6 uppercase leading-none">
        WORK LESS.<br /><span class="text-orange-400">OUTPUT MORE.</span>
      </h1>
      <p class="text-xl text-slate-600 dark:text-slate-400 max-w-2xl mx-auto font-inter leading-relaxed mb-8">
        Time arbitrage is the discipline of multiplying your output without multiplying your hours. For expat founders operating across time zones, the right systems, SOPs, and delegation stack turn the timezone gap into a compounding advantage.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/automation-systems/automate" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-orange-500 text-white font-bold text-sm hover:bg-orange-400 transition-all">
          Automate Your Operations <ArrowRight size={16} />
        </a>
        <a href="/newsletter" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl border border-slate-200 dark:border-white/10 text-slate-700 dark:text-slate-300 font-semibold text-sm hover:border-orange-500/40 transition-all">
          Weekly Intel
        </a>
      </div>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-20">
      <div class="glass-card rounded-2xl p-6 border border-orange-500/20">
        <Clock class="text-orange-400 mb-3" size={24} />
        <div class="text-3xl font-black text-slate-900 dark:text-white mb-1">6 hrs</div>
        <div class="text-sm text-slate-600 dark:text-slate-400">Average hours per week expat founders save by running async-first operations</div>
      </div>
      <div class="glass-card rounded-2xl p-6 border border-orange-500/20">
        <TrendingUp class="text-orange-400 mb-3" size={24} />
        <div class="text-3xl font-black text-slate-900 dark:text-white mb-1">3x</div>
        <div class="text-sm text-slate-600 dark:text-slate-400">Output multiplier when a founder delegates recurring tasks to a trained virtual team</div>
      </div>
      <div class="glass-card rounded-2xl p-6 border border-orange-500/20">
        <Globe class="text-orange-400 mb-3" size={24} />
        <div class="text-3xl font-black text-slate-900 dark:text-white mb-1">24/7</div>
        <div class="text-sm text-slate-600 dark:text-slate-400">Business operations when time zone differences are used as a workflow asset</div>
      </div>
    </div>

    <!-- What This Pillar Covers -->
    <div class="mb-20 prose prose-slate dark:prose-invert max-w-none">
      <h2 class="text-3xl font-black font-display uppercase tracking-tight text-slate-900 dark:text-white mb-6">What This Pillar Covers</h2>
      <p class="text-lg text-slate-600 dark:text-slate-400 leading-relaxed mb-4">
        Time is the one asset that does not scale with income. Every founder has the same 24 hours. The ones who compound fastest are not working more — they are working on fewer things, with better systems, and with the right people handling everything else.
      </p>
      <p class="text-lg text-slate-600 dark:text-slate-400 leading-relaxed mb-4">
        The time arbitrage pillar covers the full stack: how to build async operations that run without your constant presence, how to document your business so it can be delegated, how to hire and manage a virtual team from Southeast Asia, and how to use the time zone difference between your location and your clients as a competitive edge rather than a liability.
      </p>
      <p class="text-lg text-slate-600 dark:text-slate-400 leading-relaxed">
        These guides are written for expat founders who are already operating remotely and want to remove themselves as the bottleneck, and for pre-expat founders who want to build systems before they leave so the transition does not break the business.
      </p>
    </div>

    <!-- Article Index -->
    <div class="mb-20">
      <div class="flex items-center gap-3 mb-8">
        <BookOpen class="text-orange-400" size={20} />
        <h2 class="text-2xl font-black font-display uppercase tracking-tight text-slate-900 dark:text-white">All Time Arbitrage Guides</h2>
        <div class="h-px flex-1 bg-slate-200 dark:bg-white/10"></div>
        <span class="text-xs font-mono text-slate-400">{posts.length} articles</span>
      </div>

      <div class="space-y-4">
        {posts.map(post => (
          <a
            href={`/blog/${post.id.replace(/\.mdx?$/, '')}`}
            class="group flex items-start gap-5 p-5 rounded-2xl border border-slate-200 dark:border-white/10 hover:border-orange-500/40 bg-white dark:bg-white/[0.03] hover:bg-orange-500/5 transition-all duration-300"
          >
            <div class="shrink-0 w-12 h-12 rounded-xl bg-orange-500/10 flex items-center justify-center">
              <Clock class="text-orange-400" size={20} />
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-3 mb-1">
                <span class="text-xs font-mono uppercase tracking-wider text-orange-400 font-semibold">{post.data.category}</span>
                <span class="text-xs text-slate-400">{formatDate(post.data.pubDate)}</span>
                <span class="text-xs text-slate-400">{calcReadTime(post.body ?? '')} min read</span>
              </div>
              <h3 class="text-base font-bold text-slate-900 dark:text-white group-hover:text-orange-400 transition-colors leading-snug mb-1">{post.data.title}</h3>
              <p class="text-sm text-slate-500 dark:text-slate-400 line-clamp-2 leading-relaxed">{post.data.description}</p>
            </div>
            <ArrowRight class="shrink-0 text-slate-300 dark:text-slate-600 group-hover:text-orange-400 group-hover:translate-x-1 transition-all mt-1" size={18} />
          </a>
        ))}
      </div>
    </div>

    <!-- CTA -->
    <div class="rounded-2xl border border-orange-500/20 bg-orange-500/5 p-10 text-center mb-12">
      <h2 class="text-2xl font-black font-display uppercase tracking-tight text-slate-900 dark:text-white mb-3">Build a Business That Runs Without You</h2>
      <p class="text-slate-600 dark:text-slate-400 mb-6 max-w-lg mx-auto">Automation systems, SOP frameworks, and virtual team infrastructure built specifically for expat founders.</p>
      <a href="/automation-systems/automate" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl bg-orange-500 text-white font-bold hover:bg-orange-400 transition-all">
        See Automation Systems <ArrowRight size={16} />
      </a>
    </div>

  </div>
</Layout>
