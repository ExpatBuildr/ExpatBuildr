---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import { ArrowRight, Coins, BookOpen, Zap } from 'lucide-astro';
---

<Layout
  title="Market Arbitrage Resources: Finance, Currency and Edge for Expat Founders | ExpatBuildr"
  description="Everything in the Market Arbitrage pillar in one place — FEIE guides, currency strategy, investing from abroad, information arbitrage plays, and the weekly newsletter."
  canonicalUrl="https://expatbuildr.com/blog/market-arbitrage-links"
  ogImage="/images/blog/pillars/market-arbitrage-hub.png"
>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Hero -->
    <div class="text-center mb-20">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-amber-500/10 border border-amber-500/20 text-amber-400 text-xs uppercase tracking-[0.2em] font-mono mb-8">
        <Coins size={12} /> Market Arbitrage
      </div>
      <h1 class="text-5xl md:text-7xl font-black font-display tracking-tighter text-slate-900 dark:text-white mb-6 uppercase leading-none">
        EVERYTHING<br /><span class="text-amber-400">MARKET ARBITRAGE.</span>
      </h1>
      <p class="text-xl text-slate-600 dark:text-slate-400 max-w-2xl mx-auto font-inter leading-relaxed mb-8">
        Every guide and resource in the Market Arbitrage pillar — in one place. Currency strategy, FEIE, and information edge for expat founders.
      </p>
    </div>

    <!-- Featured Resources -->
    <div class="mb-12 grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="glass-card rounded-2xl p-8 border border-amber-500/30 bg-amber-500/5">
        <div class="text-xs font-mono uppercase tracking-wider text-amber-400 font-semibold mb-2">Featured Resource</div>
        <h2 class="text-xl font-black font-display uppercase tracking-tight text-slate-900 dark:text-white mb-2">Weekly Newsletter</h2>
        <p class="text-slate-600 dark:text-slate-400 leading-relaxed mb-4">Currency plays, investing from abroad, and FEIE breakdowns delivered weekly.</p>
        <a href="/newsletter" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-amber-500 text-white font-bold text-sm hover:bg-amber-400 transition-all">
          Join Free <ArrowRight size={14} />
        </a>
      </div>
      <div class="glass-card rounded-2xl p-8 border border-slate-200 dark:border-white/10 hover:border-amber-500/40 transition-all">
        <div class="text-xs font-mono uppercase tracking-wider text-amber-400 font-semibold mb-2">Shop</div>
        <h2 class="text-xl font-black font-display uppercase tracking-tight text-slate-900 dark:text-white mb-2">Digital Products</h2>
        <p class="text-slate-600 dark:text-slate-400 leading-relaxed mb-4">Calculators and tools for founders optimizing across currencies and geographies.</p>
        <a href="/shop" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-amber-500/10 text-amber-400 font-bold text-sm hover:bg-amber-500/20 transition-all">
          Browse the Shop <ArrowRight size={14} />
        </a>
      </div>
    </div>

    <!-- Recommended Tools -->
    <div class="mb-16">
      <div class="flex items-center gap-3 mb-8">
        <Zap class="text-amber-400" size={20} />
        <h2 class="text-2xl font-black font-display uppercase tracking-tight text-slate-900 dark:text-white">Recommended Tools</h2>
        <div class="h-px flex-1 bg-slate-200 dark:bg-white/10"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="p-5 rounded-xl border border-slate-200 dark:border-white/10 hover:border-amber-500/40 transition-all">
          <h3 class="text-sm font-black text-slate-900 dark:text-white mb-1">Wise</h3>
          <p class="text-xs text-slate-500 dark:text-slate-400 leading-relaxed">Currency conversion and cross-border banking at real exchange rates — the core of the founder money stack.</p>
        </div>
        <div class="p-5 rounded-xl border border-slate-200 dark:border-white/10 hover:border-amber-500/40 transition-all">
          <h3 class="text-sm font-black text-slate-900 dark:text-white mb-1">Charles Schwab</h3>
          <p class="text-xs text-slate-500 dark:text-slate-400 leading-relaxed">The standard US-expat-friendly brokerage for investing while living abroad.</p>
        </div>
        <div class="p-5 rounded-xl border border-slate-200 dark:border-white/10 hover:border-amber-500/40 transition-all">
          <h3 class="text-sm font-black text-slate-900 dark:text-white mb-1">Interactive Brokers</h3>
          <p class="text-xs text-slate-500 dark:text-slate-400 leading-relaxed">Alternative brokerage option for expats investing from abroad with broader market access.</p>
        </div>
        <div class="p-5 rounded-xl border border-slate-200 dark:border-white/10 hover:border-amber-500/40 transition-all">
          <h3 class="text-sm font-black text-slate-900 dark:text-white mb-1">Coinbase / Kraken</h3>
          <p class="text-xs text-slate-500 dark:text-slate-400 leading-relaxed">Exchanges used for on/off ramping into crypto and stablecoins as part of a borderless money stack.</p>
        </div>
        <div class="p-5 rounded-xl border border-slate-200 dark:border-white/10 hover:border-amber-500/40 transition-all">
          <h3 class="text-sm font-black text-slate-900 dark:text-white mb-1">Ledger</h3>
          <p class="text-xs text-slate-500 dark:text-slate-400 leading-relaxed">Hardware wallet recommended for securely holding crypto long-term.</p>
        </div>
      </div>
    </div>

    <!-- Content Library -->
    <div class="mb-16">
      <div class="flex items-center gap-3 mb-8">
        <BookOpen class="text-amber-400" size={20} />
        <h2 class="text-2xl font-black font-display uppercase tracking-tight text-slate-900 dark:text-white">Content Library</h2>
        <div class="h-px flex-1 bg-slate-200 dark:bg-white/10"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="p-4 rounded-xl border border-slate-200 dark:border-white/10 hover:border-amber-500/40 transition-all">
          <ul class="space-y-2">
            <li><a href="/blog/market-arbitrage/what-is-market-arbitrage" class="text-sm text-slate-700 dark:text-slate-300 hover:text-amber-400 transition-colors">What Is Market Arbitrage and How Expat Founders Use It to Build Wealth Faster</a></li>
            <li><a href="/blog/market-arbitrage/expat-founder-money-stack" class="text-sm text-slate-700 dark:text-slate-300 hover:text-amber-400 transition-colors">The Expat Founder Money Stack: Banking, Entity, and Tax Setup</a></li>
            <li><a href="/blog/market-arbitrage/investing-us-expat-what-works" class="text-sm text-slate-700 dark:text-slate-300 hover:text-amber-400 transition-colors">How to Invest as a US Expat: What Actually Works From Abroad</a></li>
            <li><a href="/blog/market-arbitrage/currency-strategy-founders-usd-sea" class="text-sm text-slate-700 dark:text-slate-300 hover:text-amber-400 transition-colors">Currency Strategy for Founders Earning in USD and Spending in SEA</a></li>
            <li><a href="/blog/market-arbitrage/feie-self-employed-expats" class="text-sm text-slate-700 dark:text-slate-300 hover:text-amber-400 transition-colors">How the Foreign Earned Income Exclusion Works for Self-Employed Expats</a></li>
          </ul>
        </div>
        <div class="p-4 rounded-xl border border-slate-200 dark:border-white/10 hover:border-amber-500/40 transition-all">
          <ul class="space-y-2">
            <li><a href="/blog/market-arbitrage/crypto-borderless-business" class="text-sm text-slate-700 dark:text-slate-300 hover:text-amber-400 transition-colors">Using Crypto to Run a Borderless Business</a></li>
            <li><a href="/blog/market-arbitrage/digital-asset-portfolio-expat-founder" class="text-sm text-slate-700 dark:text-slate-300 hover:text-amber-400 transition-colors">How to Build a Digital Asset Portfolio as an Expat Founder</a></li>
            <li><a href="/blog/market-arbitrage/expat-founder-exit-strategy" class="text-sm text-slate-700 dark:text-slate-300 hover:text-amber-400 transition-colors">The Expat Founder Exit Strategy: Building to Sell From Abroad</a></li>
            <li><a href="/blog/market-arbitrage/information-arbitrage-second-income-stream" class="text-sm text-slate-700 dark:text-slate-300 hover:text-amber-400 transition-colors">How to Use Information Arbitrage to Generate a Second Income Stream</a></li>
            <li><a href="/blog/market-arbitrage/undervalued-business-opportunities-southeast-asia" class="text-sm text-slate-700 dark:text-slate-300 hover:text-amber-400 transition-colors">How to Find Undervalued Business Opportunities in Southeast Asian Markets</a></li>
          </ul>
        </div>
      </div>

      <div class="mt-6 text-center">
        <a href="/blog/market-arbitrage" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl border border-slate-200 dark:border-white/10 text-slate-700 dark:text-slate-300 font-semibold text-sm hover:border-amber-500/40 transition-all">
          View All Market Arbitrage Guides <ArrowRight size={16} />
        </a>
      </div>
    </div>

    <!-- Newsletter CTA -->
    <div class="rounded-2xl border border-amber-500/20 bg-amber-500/5 p-10 text-center mb-12">
      <h2 class="text-2xl font-black font-display uppercase tracking-tight text-slate-900 dark:text-white mb-3">Get the Weekly Market Arbitrage Intel</h2>
      <p class="text-slate-600 dark:text-slate-400 mb-6 max-w-lg mx-auto">Currency plays, investing from abroad, FEIE breakdowns, and information arbitrage strategies — every week, free.</p>
      <a href="/newsletter" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl bg-amber-500 text-white font-bold hover:bg-amber-400 transition-all">
        Join Free <ArrowRight size={16} />
      </a>
    </div>

  </div>
</Layout>
