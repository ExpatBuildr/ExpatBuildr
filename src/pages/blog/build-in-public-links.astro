---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import { ArrowRight, Pencil, BookOpen, TrendingUp } from 'lucide-astro';
---

<Layout
  title="Build in Public Resources | ExpatBuildr"
  description="The complete resource library for building in public as an expat founder — frameworks, strategies, and real numbers from someone doing it in Cebu, Philippines."
  canonicalUrl="https://expatbuildr.com/blog/build-in-public-links"
>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Hero -->
    <div class="text-center mb-20">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-violet-400/10 border border-violet-400/20 text-violet-400 text-xs uppercase tracking-[0.2em] font-mono mb-8">
        <Pencil size={12} /> Build in Public
      </div>
      <h1 class="text-5xl md:text-7xl font-black font-display tracking-tighter text-slate-900 dark:text-white mb-6 uppercase leading-none">
        BUILD IN<br /><span class="text-violet-400">PUBLIC.</span>
      </h1>
      <p class="text-xl text-slate-600 dark:text-slate-400 max-w-2xl mx-auto font-inter leading-relaxed mb-8">
        Documenting the real numbers, the real decisions, and the real mistakes behind building a media company from Cebu, Philippines. The outcomes are public. The mechanics stay private.
      </p>
    </div>

    <!-- Definition -->
    <div class="mb-12">
      <div class="glass-card rounded-2xl p-8 border border-violet-400/30 bg-violet-400/5">
        <div class="text-xs font-mono uppercase tracking-wider text-violet-400 font-semibold mb-3">What is building in public?</div>
        <p class="text-slate-600 dark:text-slate-400 leading-relaxed">Building in public means sharing your progress, your metrics, and your lessons as you build — not after you succeed. It creates trust faster than any marketing campaign, attracts the right audience before you have anything to sell, and turns your journey into content that compounds over time. The key distinction: share outcomes and frameworks publicly. Keep the core mechanisms private until the moat is permanent.</p>
      </div>
    </div>

    <!-- Galaxy Arbitrage Weekly Story -->
    <div class="mb-16">
      <div class="flex items-center gap-3 mb-8">
        <BookOpen class="text-violet-400" size={20} />
        <h2 class="text-2xl font-black font-display uppercase tracking-tight text-slate-900 dark:text-white">The Galaxy Arbitrage Weekly Story</h2>
        <div class="h-px flex-1 bg-slate-200 dark:bg-white/10"></div>
      </div>

      <div class="space-y-3">
        <a href="https://newsletter.galaxyarbitrage.com/p/philippines-expat-reality-nobody-talks-about" class="block p-5 rounded-xl border border-slate-200 dark:border-white/10 hover:border-violet-400/40 transition-all group">
          <div class="flex items-center justify-between gap-4">
            <div>
              <p class="text-sm font-black text-slate-900 dark:text-white mb-1">Issue 3 — The Philippines Expat Reality Nobody Talks About</p>
              <p class="text-sm text-slate-500 dark:text-slate-400">Three times I left. This time I'm staying. Here's what the math doesn't tell you.</p>
            </div>
            <ArrowRight class="text-violet-400 shrink-0 group-hover:translate-x-1 transition-transform" size={18} />
          </div>
        </a>
        <a href="https://newsletter.galaxyarbitrage.com/p/expat-income-stack" class="block p-5 rounded-xl border border-slate-200 dark:border-white/10 hover:border-violet-400/40 transition-all group">
          <div class="flex items-center justify-between gap-4">
            <div>
              <p class="text-sm font-black text-slate-900 dark:text-white mb-1">Issue 4 — The Expat Income Stack</p>
              <p class="text-sm text-slate-500 dark:text-slate-400">How to structure your money so you never have to go home.</p>
            </div>
            <ArrowRight class="text-violet-400 shrink-0 group-hover:translate-x-1 transition-transform" size={18} />
          </div>
        </a>
      </div>
      <p class="text-xs font-mono uppercase tracking-wider text-slate-400 mt-4">New issues every Tuesday. Subscribe to follow the build in real time.</p>
    </div>

    <!-- Frameworks -->
    <div class="mb-16">
      <div class="flex items-center gap-3 mb-8">
        <TrendingUp class="text-violet-400" size={20} />
        <h2 class="text-2xl font-black font-display uppercase tracking-tight text-slate-900 dark:text-white">Frameworks</h2>
        <div class="h-px flex-1 bg-slate-200 dark:bg-white/10"></div>
      </div>

      <a href="/founder-stack" class="block p-5 rounded-xl border border-slate-200 dark:border-white/10 hover:border-violet-400/40 transition-all group">
        <div class="flex items-center justify-between gap-4">
          <div>
            <p class="text-sm font-black text-slate-900 dark:text-white mb-1">The Expat Founder Stack — Free Checklist</p>
            <p class="text-sm text-slate-500 dark:text-slate-400">The tools and infrastructure behind building a location-independent operation from the 15 Diamond Countries.</p>
          </div>
          <ArrowRight class="text-violet-400 shrink-0 group-hover:translate-x-1 transition-transform" size={18} />
        </div>
      </a>
    </div>

    <!-- Milestones -->
    <div class="mb-16">
      <div class="flex items-center gap-3 mb-8">
        <TrendingUp class="text-violet-400" size={20} />
        <h2 class="text-2xl font-black font-display uppercase tracking-tight text-slate-900 dark:text-white">Milestones</h2>
        <div class="h-px flex-1 bg-slate-200 dark:bg-white/10"></div>
      </div>

      <div class="space-y-3">
        <div class="p-5 rounded-xl border border-slate-200 dark:border-white/10 flex gap-5">
          <div class="text-xs font-mono uppercase tracking-wider text-violet-400 shrink-0 pt-0.5">Week 9</div>
          <div>
            <p class="text-sm font-black text-slate-900 dark:text-white mb-1">1,000+ subscribers · $98 total ad spend</p>
            <p class="text-sm text-slate-500 dark:text-slate-400">Galaxy Arbitrage Weekly hit 1,000 verified subscribers in under 10 weeks. 20%+ open rates. 5-7% click rates. Monetization live with Issue 3.</p>
          </div>
        </div>
        <div class="p-5 rounded-xl border border-slate-200 dark:border-white/10 flex gap-5">
          <div class="text-xs font-mono uppercase tracking-wider text-violet-400 shrink-0 pt-0.5">Week 6</div>
          <div>
            <p class="text-sm font-black text-slate-900 dark:text-white mb-1">Product market fit confirmed</p>
            <p class="text-sm text-slate-500 dark:text-slate-400">Issue 1 hit 7%+ click rates — 3x industry average — on a list that still had dead weight. The audience was right before the content was optimized.</p>
          </div>
        </div>
        <div class="p-5 rounded-xl border border-slate-200 dark:border-white/10 flex gap-5">
          <div class="text-xs font-mono uppercase tracking-wider text-violet-400 shrink-0 pt-0.5">Week 1</div>
          <div>
            <p class="text-sm font-black text-slate-900 dark:text-white mb-1">$98 into ads. First issue sent to 309 subscribers.</p>
            <p class="text-sm text-slate-500 dark:text-slate-400">23% open rate on the first issue. The targeting worked. The list was real.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Related Pillars -->
    <div class="mb-16">
      <div class="flex items-center gap-3 mb-8">
        <BookOpen class="text-violet-400" size={20} />
        <h2 class="text-2xl font-black font-display uppercase tracking-tight text-slate-900 dark:text-white">Related Pillars</h2>
        <div class="h-px flex-1 bg-slate-200 dark:bg-white/10"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <a href="/blog/geo-arbitrage-links" class="block p-5 rounded-xl border border-slate-200 dark:border-white/10 hover:border-violet-400/40 transition-all group">
          <div class="flex items-center justify-between gap-4">
            <div>
              <p class="text-sm font-black text-slate-900 dark:text-white mb-1">Geo-Arbitrage Resources</p>
              <p class="text-sm text-slate-500 dark:text-slate-400">Country guides, cost breakdowns, and move planning tools</p>
            </div>
            <ArrowRight class="text-violet-400 shrink-0 group-hover:translate-x-1 transition-transform" size={18} />
          </div>
        </a>
        <a href="/blog/time-arbitrage-links" class="block p-5 rounded-xl border border-slate-200 dark:border-white/10 hover:border-violet-400/40 transition-all group">
          <div class="flex items-center justify-between gap-4">
            <div>
              <p class="text-sm font-black text-slate-900 dark:text-white mb-1">Time & AI Arbitrage Resources</p>
              <p class="text-sm text-slate-500 dark:text-slate-400">AI leverage, automation, and async systems for solo founders</p>
            </div>
            <ArrowRight class="text-violet-400 shrink-0 group-hover:translate-x-1 transition-transform" size={18} />
          </div>
        </a>
      </div>
    </div>

    <!-- Newsletter CTA -->
    <div class="rounded-2xl border border-violet-400/20 bg-violet-400/5 p-10 text-center mb-12">
      <h2 class="text-2xl font-black font-display uppercase tracking-tight text-slate-900 dark:text-white mb-3">Follow the Build in Real Time</h2>
      <p class="text-slate-600 dark:text-slate-400 mb-6 max-w-lg mx-auto">Real numbers. Real decisions. Real mistakes. Galaxy Arbitrage Weekly documents the comeback from $300K lost to a sustainable media operation — in public, every Tuesday.</p>
      <a href="https://newsletter.galaxyarbitrage.com/subscribe" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl bg-violet-400 text-black font-bold hover:bg-violet-300 transition-all">
        Subscribe Free <ArrowRight size={16} />
      </a>
    </div>

  </div>
</Layout>
