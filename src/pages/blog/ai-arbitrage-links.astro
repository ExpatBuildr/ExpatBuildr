---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import { ArrowRight, Sparkles, BookOpen, TrendingUp } from 'lucide-astro';
---

<Layout
  title="AI Arbitrage Resources: Tools, Workflows and Guides | ExpatBuildr"
  description="Everything in the AI Arbitrage pillar in one place — AI tool stacks, workflow guides, automation systems, and the weekly newsletter for expat founders competing at scale."
  canonicalUrl="https://expatbuildr.com/blog/ai-arbitrage-links"
  ogImage="/images/blog/pillars/ai-arbitrage-hub.png"
>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Hero -->
    <div class="text-center mb-20">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-violet-500/10 border border-violet-500/20 text-violet-400 text-xs uppercase tracking-[0.2em] font-mono mb-8">
        <Sparkles size={12} /> AI Arbitrage
      </div>
      <h1 class="text-5xl md:text-7xl font-black font-display tracking-tighter text-slate-900 dark:text-white mb-6 uppercase leading-none">
        EVERYTHING<br /><span class="text-violet-400">AI ARBITRAGE.</span>
      </h1>
      <p class="text-xl text-slate-600 dark:text-slate-400 max-w-2xl mx-auto font-inter leading-relaxed mb-8">
        Every tool, resource, and guide in the AI Arbitrage pillar — in one place. Build the AI stack that gives you team-size output on a solo budget.
      </p>
    </div>

    <!-- Featured Service -->
    <div class="mb-12">
      <div class="glass-card rounded-2xl p-8 border border-violet-500/30 bg-violet-500/5">
        <div class="flex flex-col md:flex-row md:items-center gap-6">
          <div class="shrink-0 w-16 h-16 rounded-2xl bg-violet-500/10 flex items-center justify-center">
            <TrendingUp class="text-violet-400" size={28} />
          </div>
          <div class="flex-1">
            <div class="text-xs font-mono uppercase tracking-wider text-violet-400 font-semibold mb-2">Featured Service</div>
            <h2 class="text-2xl font-black font-display uppercase tracking-tight text-slate-900 dark:text-white mb-2">Automation Systems</h2>
            <p class="text-slate-600 dark:text-slate-400 leading-relaxed mb-4">Multi-agent systems, AI workflows, and automation infrastructure built for expat founders running lean.</p>
            <a href="/automation-systems/automate" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-violet-500 text-white font-bold text-sm hover:bg-violet-400 transition-all">
              See How It Works <ArrowRight size={16} />
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Services -->
    <div class="mb-16">
      <div class="flex items-center gap-3 mb-8">
        <TrendingUp class="text-violet-400" size={20} />
        <h2 class="text-2xl font-black font-display uppercase tracking-tight text-slate-900 dark:text-white">Done-For-You Services</h2>
        <div class="h-px flex-1 bg-slate-200 dark:bg-white/10"></div>
      </div>

      <div class="glass-card rounded-2xl p-8 border border-slate-200 dark:border-white/10 hover:border-violet-500/40 transition-all">
        <div class="flex flex-col md:flex-row md:items-center gap-6">
          <div class="flex-1">
            <div class="text-xs font-mono uppercase tracking-wider text-violet-400 font-semibold mb-2">Automation Service</div>
            <h3 class="text-xl font-black text-slate-900 dark:text-white mb-2">AI Workflow Buildout</h3>
            <p class="text-slate-600 dark:text-slate-400 leading-relaxed mb-4">We design and deploy the AI agent stack — research, outreach, content, data — so you operate at team-size output solo.</p>
            <a href="/automation-systems/automation" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-violet-500/10 text-violet-400 font-bold text-sm hover:bg-violet-500/20 transition-all">
              Learn More <ArrowRight size={14} />
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Content Library -->
    <div class="mb-16">
      <div class="flex items-center gap-3 mb-8">
        <BookOpen class="text-violet-400" size={20} />
        <h2 class="text-2xl font-black font-display uppercase tracking-tight text-slate-900 dark:text-white">Content Library</h2>
        <div class="h-px flex-1 bg-slate-200 dark:bg-white/10"></div>
      </div>

      <div class="p-4 rounded-xl border border-slate-200 dark:border-white/10">
        <p class="text-sm text-slate-500 dark:text-slate-400 mb-3">Articles in this pillar are in production:</p>
        <ul class="space-y-2 list-disc list-inside">
          <li class="text-sm text-slate-700 dark:text-slate-300">What Is AI Arbitrage and How Founders Use It to Compete at Any Scale</li>
          <li class="text-sm text-slate-700 dark:text-slate-300">The Expat Founder AI Stack: Tools That Replace an Entire Team</li>
          <li class="text-sm text-slate-700 dark:text-slate-300">How to Use AI for Cold Outreach Without Losing the Human Signal</li>
          <li class="text-sm text-slate-700 dark:text-slate-300">How to Build AI Workflows That Run Your Business While You Sleep</li>
          <li class="text-sm text-slate-700 dark:text-slate-300">Prompt Engineering for Founders: Getting Consistent Output From AI Tools</li>
        </ul>
      </div>

      <div class="mt-6 text-center">
        <a href="/blog/ai-arbitrage" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl border border-slate-200 dark:border-white/10 text-slate-700 dark:text-slate-300 font-semibold text-sm hover:border-violet-500/40 transition-all">
          View All AI Arbitrage Guides <ArrowRight size={16} />
        </a>
      </div>
    </div>

    <!-- Newsletter CTA -->
    <div class="rounded-2xl border border-violet-500/20 bg-violet-500/5 p-10 text-center mb-12">
      <h2 class="text-2xl font-black font-display uppercase tracking-tight text-slate-900 dark:text-white mb-3">Get Your AI-Powered Founder Stack</h2>
      <p class="text-slate-600 dark:text-slate-400 mb-6 max-w-lg mx-auto">Multi-agent systems, AI workflows, and automation infrastructure — every week, free.</p>
      <a href="/newsletter" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl bg-violet-500 text-white font-bold hover:bg-violet-400 transition-all">
        Join Free <ArrowRight size={16} />
      </a>
    </div>

  </div>
</Layout>
