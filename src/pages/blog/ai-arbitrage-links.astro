---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import { ArrowRight, Sparkles, BookOpen, TrendingUp, Zap } from 'lucide-astro';
---

<Layout
  title="AI Arbitrage Resources: Tools, Workflows and Guides | ExpatBuildr"
  description="Everything in the AI Arbitrage pillar in one place — AI tool stacks, workflow guides, automation systems, and the weekly newsletter for expat founders competing at scale."
  canonicalUrl="https://expatbuildr.com/blog/ai-arbitrage-links"
  ogImage="/images/blog/pillars/ai-arbitrage-hub.png"
>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Hero -->
    <div class="text-center mb-20">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-violet-500/10 border border-violet-500/20 text-violet-400 text-xs uppercase tracking-[0.2em] font-mono mb-8">
        <Sparkles size={12} /> AI Arbitrage
      </div>
      <h1 class="text-5xl md:text-7xl font-black font-display tracking-tighter text-slate-900 dark:text-white mb-6 uppercase leading-none">
        EVERYTHING<br /><span class="text-violet-400">AI ARBITRAGE.</span>
      </h1>
      <p class="text-xl text-slate-600 dark:text-slate-400 max-w-2xl mx-auto font-inter leading-relaxed mb-8">
        Every tool, resource, and guide in the AI Arbitrage pillar — in one place. Build the AI stack that gives you team-size output on a solo budget.
      </p>
    </div>

    <!-- Featured Service -->
    <div class="mb-12">
      <div class="glass-card rounded-2xl p-8 border border-violet-500/30 bg-violet-500/5">
        <div class="flex flex-col md:flex-row md:items-center gap-6">
          <div class="shrink-0 w-16 h-16 rounded-2xl bg-violet-500/10 flex items-center justify-center">
            <TrendingUp class="text-violet-400" size={28} />
          </div>
          <div class="flex-1">
            <div class="text-xs font-mono uppercase tracking-wider text-violet-400 font-semibold mb-2">Featured Service</div>
            <h2 class="text-2xl font-black font-display uppercase tracking-tight text-slate-900 dark:text-white mb-2">Automation Systems</h2>
            <p class="text-slate-600 dark:text-slate-400 leading-relaxed mb-4">Multi-agent systems, AI workflows, and automation infrastructure built for expat founders running lean.</p>
            <a href="/automation-systems/automate" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-violet-500 text-white font-bold text-sm hover:bg-violet-400 transition-all">
              See How It Works <ArrowRight size={16} />
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Services -->
    <div class="mb-16">
      <div class="flex items-center gap-3 mb-8">
        <TrendingUp class="text-violet-400" size={20} />
        <h2 class="text-2xl font-black font-display uppercase tracking-tight text-slate-900 dark:text-white">Done-For-You Services</h2>
        <div class="h-px flex-1 bg-slate-200 dark:bg-white/10"></div>
      </div>

      <div class="glass-card rounded-2xl p-8 border border-slate-200 dark:border-white/10 hover:border-violet-500/40 transition-all">
        <div class="flex flex-col md:flex-row md:items-center gap-6">
          <div class="flex-1">
            <div class="text-xs font-mono uppercase tracking-wider text-violet-400 font-semibold mb-2">Automation Service</div>
            <h3 class="text-xl font-black text-slate-900 dark:text-white mb-2">AI Workflow Buildout</h3>
            <p class="text-slate-600 dark:text-slate-400 leading-relaxed mb-4">We design and deploy the AI agent stack — research, outreach, content, data — so you operate at team-size output solo.</p>
            <a href="/automation-systems/automation" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-violet-500/10 text-violet-400 font-bold text-sm hover:bg-violet-500/20 transition-all">
              Learn More <ArrowRight size={14} />
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Recommended Tools -->
    <div class="mb-16">
      <div class="flex items-center gap-3 mb-8">
        <Zap class="text-violet-400" size={20} />
        <h2 class="text-2xl font-black font-display uppercase tracking-tight text-slate-900 dark:text-white">Recommended Tools</h2>
        <div class="h-px flex-1 bg-slate-200 dark:bg-white/10"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="p-5 rounded-xl border border-slate-200 dark:border-white/10 hover:border-violet-500/40 transition-all">
          <h3 class="text-sm font-black text-slate-900 dark:text-white mb-1">Claude</h3>
          <p class="text-xs text-slate-500 dark:text-slate-400 leading-relaxed">Research, writing, strategy, and the core of most AI workflows built into the expat founder stack.</p>
        </div>
        <div class="p-5 rounded-xl border border-slate-200 dark:border-white/10 hover:border-violet-500/40 transition-all">
          <h3 class="text-sm font-black text-slate-900 dark:text-white mb-1">ChatGPT</h3>
          <p class="text-xs text-slate-500 dark:text-slate-400 leading-relaxed">Versatile assistant for content, research, and prompt-based workflows across the AI stack.</p>
        </div>
        <div class="p-5 rounded-xl border border-slate-200 dark:border-white/10 hover:border-violet-500/40 transition-all">
          <h3 class="text-sm font-black text-slate-900 dark:text-white mb-1">Make.com</h3>
          <p class="text-xs text-slate-500 dark:text-slate-400 leading-relaxed">Automation layer that connects AI tools into workflows that run without daily intervention.</p>
        </div>
        <div class="p-5 rounded-xl border border-slate-200 dark:border-white/10 hover:border-violet-500/40 transition-all">
          <h3 class="text-sm font-black text-slate-900 dark:text-white mb-1">Notion</h3>
          <p class="text-xs text-slate-500 dark:text-slate-400 leading-relaxed">Documentation hub for prompts, SOPs, and the AI workflows that keep the business async.</p>
        </div>
        <div class="p-5 rounded-xl border border-slate-200 dark:border-white/10 hover:border-violet-500/40 transition-all">
          <h3 class="text-sm font-black text-slate-900 dark:text-white mb-1">Loom</h3>
          <p class="text-xs text-slate-500 dark:text-slate-400 leading-relaxed">Screen recording for documenting AI workflows and training a team or VA on the system.</p>
        </div>
      </div>
    </div>

    <!-- Content Library -->
    <div class="mb-16">
      <div class="flex items-center gap-3 mb-8">
        <BookOpen class="text-violet-400" size={20} />
        <h2 class="text-2xl font-black font-display uppercase tracking-tight text-slate-900 dark:text-white">Content Library</h2>
        <div class="h-px flex-1 bg-slate-200 dark:bg-white/10"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="p-4 rounded-xl border border-slate-200 dark:border-white/10 hover:border-violet-500/40 transition-all">
          <ul class="space-y-2">
            <li><a href="/blog/ai-arbitrage/what-is-ai-arbitrage" class="text-sm text-slate-700 dark:text-slate-300 hover:text-violet-400 transition-colors">What Is AI Arbitrage and How Founders Use It to Compete at Any Scale</a></li>
            <li><a href="/blog/ai-arbitrage/expat-founder-ai-stack" class="text-sm text-slate-700 dark:text-slate-300 hover:text-violet-400 transition-colors">The Expat Founder AI Stack: Tools That Replace an Entire Team</a></li>
            <li><a href="/blog/ai-arbitrage/ai-cold-outreach-human-signal" class="text-sm text-slate-700 dark:text-slate-300 hover:text-violet-400 transition-colors">How to Use AI for Cold Outreach Without Losing the Human Signal</a></li>
            <li><a href="/blog/ai-arbitrage/ai-workflows-run-business-while-you-sleep" class="text-sm text-slate-700 dark:text-slate-300 hover:text-violet-400 transition-colors">How to Build AI Workflows That Run Your Business While You Sleep</a></li>
            <li><a href="/blog/ai-arbitrage/prompt-engineering-for-founders" class="text-sm text-slate-700 dark:text-slate-300 hover:text-violet-400 transition-colors">Prompt Engineering for Founders: Getting Consistent Output From AI Tools</a></li>
          </ul>
        </div>
        <div class="p-4 rounded-xl border border-slate-200 dark:border-white/10 hover:border-violet-500/40 transition-all">
          <ul class="space-y-2">
            <li><a href="/blog/ai-arbitrage/ai-chief-of-staff-for-your-business" class="text-sm text-slate-700 dark:text-slate-300 hover:text-violet-400 transition-colors">How to Build an AI Chief of Staff for Your Business</a></li>
            <li><a href="/blog/ai-arbitrage/ai-competitive-intelligence-solo-expat-founder" class="text-sm text-slate-700 dark:text-slate-300 hover:text-violet-400 transition-colors">Using AI for Competitive Intelligence as a Solo Expat Founder</a></li>
            <li><a href="/blog/ai-arbitrage/ai-content-system-week-of-content-one-hour" class="text-sm text-slate-700 dark:text-slate-300 hover:text-violet-400 transition-colors">How to Build an AI Content System That Produces a Week of Content in One Hour</a></li>
            <li><a href="/blog/ai-arbitrage/audit-improve-ai-stack-90-days" class="text-sm text-slate-700 dark:text-slate-300 hover:text-violet-400 transition-colors">How to Audit and Improve Your AI Stack Every 90 Days</a></li>
            <li><a href="/blog/ai-arbitrage/automate-client-onboarding-ai" class="text-sm text-slate-700 dark:text-slate-300 hover:text-violet-400 transition-colors">How to Automate Your Client Onboarding With AI</a></li>
          </ul>
        </div>
      </div>

      <div class="mt-6 text-center">
        <a href="/blog/ai-arbitrage" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl border border-slate-200 dark:border-white/10 text-slate-700 dark:text-slate-300 font-semibold text-sm hover:border-violet-500/40 transition-all">
          View All AI Arbitrage Guides <ArrowRight size={16} />
        </a>
      </div>
    </div>

    <!-- Newsletter CTA -->
    <div class="rounded-2xl border border-violet-500/20 bg-violet-500/5 p-10 text-center mb-12">
      <h2 class="text-2xl font-black font-display uppercase tracking-tight text-slate-900 dark:text-white mb-3">Get Your AI-Powered Founder Stack</h2>
      <p class="text-slate-600 dark:text-slate-400 mb-6 max-w-lg mx-auto">Multi-agent systems, AI workflows, and automation infrastructure — every week, free.</p>
      <a href="/newsletter" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl bg-violet-500 text-white font-bold hover:bg-violet-400 transition-all">
        Join Free <ArrowRight size={16} />
      </a>
    </div>

  </div>
</Layout>
