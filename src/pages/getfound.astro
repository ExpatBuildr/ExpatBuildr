---
// /getfound — Google Business Profile Setup & Management
// Standalone sales page — no funnel dependency, sells directly.
// Used for the "no GBP" or "weak GBP" lead category from GalaxyConverts.
const TEXT_NUMBER = "+13104618859";
const TEXT_NUMBER_DISPLAY = "(310) 461-8859";
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Get Found on Google — GBP Setup & Management | ExpatBuildr</title>
  <meta name="description" content="Your business should show up when people search for you. We set up and manage your Google Business Profile so you get found first — $300 setup, $150/month after." />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Syne:wght@400;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

  <script is:inline>
    const theme = (() => {
      if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
        return localStorage.getItem('theme');
      }
      return 'light';
    })();
    if (theme === 'light') {
      document.documentElement.classList.remove('dark');
    } else {
      document.documentElement.classList.add('dark');
    }
    window.localStorage.setItem('theme', theme);
  </script>

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --gold: #3b82f6;
      --orange: #8b5cf6;
      --cyan: #22d3ee;
      --emerald: #0a9e5c;
      --red: #d92d4c;
      --bg-deep: #faf5ff;
      --bg-glass: rgba(2,6,23,0.035);
      --bg-glass-hover: rgba(2,6,23,0.06);
      --bg-featured: rgba(59,130,246,0.06);
      --border-glass: rgba(217,70,239,0.12);
      --border-gold: rgba(59,130,246,0.35);
      --border-gold-dim: rgba(59,130,246,0.16);
      --text-primary: #020617;
      --text-muted: #475569;
      --text-dim: #64748b;
      --nav-bg: rgba(250,245,255,0.92);
      --btn-ink: #ffffff;
      --mock-bg: #f3e8ff;
    }

    html.dark {
      --gold: #f5a623;
      --orange: #ff6b35;
      --cyan: #00d4ff;
      --emerald: #00e87a;
      --red: #ff2d55;
      --bg-deep: #060809;
      --bg-glass: rgba(255,255,255,0.028);
      --bg-glass-hover: rgba(255,255,255,0.05);
      --bg-featured: rgba(245,166,35,0.06);
      --border-glass: rgba(255,255,255,0.07);
      --border-gold: rgba(245,166,35,0.35);
      --border-gold-dim: rgba(245,166,35,0.15);
      --text-primary: #f0ece4;
      --text-muted: rgba(240,236,228,0.52);
      --text-dim: rgba(240,236,228,0.28);
      --nav-bg: rgba(6,8,9,0.9);
      --btn-ink: #060809;
      --mock-bg: #0d0f10;
    }

    html { scroll-behavior: smooth; }
    body {
      background: var(--bg-deep); color: var(--text-primary);
      font-family: 'Syne', sans-serif; min-height: 100vh; overflow-x: hidden;
    }

    .bg-layer { position: fixed; inset: 0; z-index: 0; pointer-events: none; }
    .bg-grid {
      position: absolute; inset: 0;
      background-image:
        linear-gradient(rgba(245,166,35,0.035) 1px, transparent 1px),
        linear-gradient(90deg, rgba(245,166,35,0.035) 1px, transparent 1px);
      background-size: 72px 72px;
    }
    .bg-orbs {
      position: absolute; inset: 0;
      background:
        radial-gradient(ellipse 55% 40% at 15% 10%, rgba(0,232,122,0.07) 0%, transparent 55%),
        radial-gradient(ellipse 50% 35% at 90% 25%, rgba(245,166,35,0.06) 0%, transparent 50%),
        radial-gradient(ellipse 60% 45% at 50% 95%, rgba(0,212,255,0.04) 0%, transparent 55%);
    }
    .bg-scanlines {
      position: absolute; inset: 0;
      background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.08) 2px, rgba(0,0,0,0.08) 4px);
      opacity: 0.4;
    }

    nav {
      position: sticky; top: 0; z-index: 100;
      background: var(--nav-bg); backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border-glass);
    }
    .nav-inner {
      max-width: 1080px; margin: 0 auto; padding: 18px 24px;
      display: flex; align-items: center; justify-content: space-between;
    }
    .nav-logo {
      display: inline-flex; align-items: center; gap: 8px;
      font-family: 'Bebas Neue', sans-serif; font-size: 1.4rem; letter-spacing: 0.12em; color: var(--gold); text-decoration: none;
    }
    .nav-logo img { width: 28px; height: 28px; border-radius: 6px; object-fit: cover; flex-shrink: 0; }
    .nav-right { display: flex; align-items: center; gap: 20px; }
    .theme-toggle {
      display: inline-flex; align-items: center; justify-content: center;
      width: 30px; height: 30px; border-radius: 50%;
      background: var(--bg-glass); border: 1px solid var(--border-glass);
      color: var(--text-muted); cursor: pointer; font-size: 0.85rem; flex-shrink: 0;
    }
    .theme-toggle:hover { border-color: var(--border-gold); color: var(--gold); }
    .nav-cta {
      font-family: 'JetBrains Mono', monospace; font-size: 0.68rem; font-weight: 500; letter-spacing: 0.1em;
      text-transform: uppercase; text-decoration: none; padding: 8px 16px;
      background: linear-gradient(135deg, var(--gold), var(--orange)); color: var(--btn-ink);
      transition: filter 0.15s ease, transform 0.15s ease;
    }
    .nav-cta:hover { filter: brightness(1.1); transform: translateY(-1px); }

    .page { position: relative; z-index: 1; max-width: 1080px; margin: 0 auto; padding: 0 24px; }

    /* HERO */
    .hero { padding: 76px 0 56px; text-align: center; }
    .hero-eyebrow {
      display: inline-flex; align-items: center; gap: 8px;
      font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; letter-spacing: 0.2em;
      text-transform: uppercase; color: var(--emerald); margin-bottom: 24px;
      padding: 6px 12px; background: rgba(0,232,122,0.06); border: 1px solid rgba(0,232,122,0.15);
    }
    .hero-eyebrow::before { content: ''; width: 5px; height: 5px; border-radius: 50%; background: var(--emerald); animation: blink 2s ease infinite; }
    @keyframes blink { 0%,100% { opacity: 1; } 50% { opacity: 0.2; } }
    .hero-headline {
      font-family: 'Bebas Neue', sans-serif; font-size: clamp(2.6rem, 6vw, 4.6rem);
      line-height: 0.95; letter-spacing: 0.02em; margin-bottom: 20px;
    }
    .hero-headline .hl-white { color: var(--text-primary); }
    .hero-headline .hl-gold { color: var(--gold); }
    .hero-sub {
      font-size: 1rem; line-height: 1.7; color: var(--text-muted);
      max-width: 560px; margin: 0 auto 32px;
    }
    .hero-sub strong { color: var(--text-primary); }
    .hero-actions { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
    .btn-primary {
      display: inline-flex; align-items: center; justify-content: center; gap: 8px;
      font-family: 'Bebas Neue', sans-serif; font-size: 1.1rem; letter-spacing: 0.1em;
      text-decoration: none; padding: 16px 28px;
      background: linear-gradient(135deg, var(--gold), var(--orange)); color: var(--btn-ink);
      transition: transform 0.15s ease, box-shadow 0.15s ease;
    }
    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 12px 40px rgba(245,166,35,0.3); }
    .btn-secondary {
      display: inline-flex; align-items: center; justify-content: center; gap: 8px;
      font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; letter-spacing: 0.12em; text-transform: uppercase;
      text-decoration: none; padding: 13px 24px; background: transparent;
      border: 1px solid var(--border-glass); color: var(--text-muted);
      transition: border-color 0.2s ease, color 0.2s ease;
    }
    .btn-secondary:hover { border-color: var(--gold); color: var(--gold); }

    section { padding: 64px 0; border-top: 1px solid var(--border-glass); }
    .section-eyebrow {
      font-family: 'JetBrains Mono', monospace; font-size: 0.62rem; letter-spacing: 0.22em;
      text-transform: uppercase; color: var(--text-dim); margin-bottom: 16px;
      display: flex; align-items: center; gap: 12px;
    }
    .section-eyebrow::after { content: ''; flex: 0 0 40px; height: 1px; background: var(--border-glass); }
    .section-headline {
      font-family: 'Bebas Neue', sans-serif; font-size: clamp(2.2rem, 4vw, 3.2rem);
      line-height: 0.95; letter-spacing: 0.02em; margin-bottom: 40px;
    }
    .section-headline em { font-style: normal; color: var(--gold); }

    /* GBP MOCKUP COMPARISON */
    .gbp-compare { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    .gbp-card { border-radius: 8px; overflow: hidden; border: 1px solid var(--border-glass); background: var(--mock-bg); }
    .gbp-card.bad { border-color: rgba(217,45,76,0.3); }
    .gbp-card.good { border-color: rgba(10,158,92,0.3); }
    .gbp-head {
      padding: 10px 16px; display: flex; align-items: center; justify-content: space-between;
      font-family: 'JetBrains Mono', monospace; font-size: 0.62rem; letter-spacing: 0.1em; text-transform: uppercase;
    }
    .gbp-card.bad .gbp-head { background: rgba(217,45,76,0.08); color: var(--red); }
    .gbp-card.good .gbp-head { background: rgba(10,158,92,0.08); color: var(--emerald); }

    /* "not found" mock */
    .gbp-body-bad { padding: 40px 24px; text-align: center; }
    .not-found-icon {
      width: 56px; height: 56px; border-radius: 50%; border: 2px solid rgba(217,45,76,0.4);
      display: flex; align-items: center; justify-content: center; margin: 0 auto 16px;
      font-family: 'Bebas Neue', sans-serif; font-size: 1.8rem; color: var(--red);
    }
    .not-found-text { font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; color: var(--text-muted); line-height: 1.6; }
    .not-found-text strong { color: var(--text-primary); }

    /* "found" mock — mimics a knowledge panel */
    .gbp-body-good { padding: 18px; }
    .gbp-biz-name { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 1.05rem; margin-bottom: 4px; }
    .gbp-stars { color: var(--gold); font-size: 0.85rem; margin-bottom: 4px; }
    .gbp-stars span { color: var(--text-dim); font-family: 'JetBrains Mono', monospace; font-size: 0.62rem; margin-left: 4px; }
    .gbp-meta { font-family: 'JetBrains Mono', monospace; font-size: 0.62rem; color: var(--text-dim); margin-bottom: 12px; }
    .gbp-open { color: var(--emerald); }
    .gbp-photo-strip { display: grid; grid-template-columns: repeat(4, 1fr); gap: 4px; margin-bottom: 12px; }
    .gbp-photo-strip div { aspect-ratio: 1; border-radius: 3px; background: linear-gradient(135deg, rgba(0,212,255,0.15), rgba(245,166,35,0.12)); }
    .gbp-actions { display: flex; gap: 6px; margin-bottom: 12px; }
    .gbp-actions span {
      font-family: 'JetBrains Mono', monospace; font-size: 0.58rem; letter-spacing: 0.05em; text-transform: uppercase;
      padding: 6px 10px; border-radius: 4px; background: rgba(10,158,92,0.1); color: var(--emerald); border: 1px solid rgba(10,158,92,0.25);
    }
    .gbp-review {
      background: var(--bg-glass); border-radius: 6px; padding: 10px 12px; margin-bottom: 6px;
    }
    .gbp-review-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px; }
    .gbp-review-name { font-family: 'JetBrains Mono', monospace; font-size: 0.6rem; color: var(--text-muted); }
    .gbp-review-reply {
      font-size: 0.68rem; color: var(--text-dim); line-height: 1.4; padding-left: 10px;
      border-left: 2px solid var(--emerald); margin-top: 6px;
    }
    .gbp-review-reply strong { color: var(--emerald); }

    .compare-flaws { padding: 14px 16px 18px; }
    .compare-flaws li {
      list-style: none; display: flex; gap: 8px; align-items: flex-start;
      font-size: 0.78rem; line-height: 1.5; color: var(--text-muted); padding: 5px 0;
    }
    .gbp-card.bad .compare-flaws li::before { content: '✕'; color: var(--red); flex-shrink: 0; font-size: 0.7rem; }
    .gbp-card.good .compare-flaws li::before { content: '✓'; color: var(--emerald); flex-shrink: 0; font-size: 0.7rem; }

    /* WHAT WE DO */
    .service-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1px; background: var(--border-glass); border: 1px solid var(--border-glass); }
    .service-item { background: var(--bg-deep); padding: 26px 24px; }
    .service-icon { font-family: 'Bebas Neue', sans-serif; font-size: 1.6rem; color: var(--emerald); margin-bottom: 10px; }
    .service-title { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 0.95rem; margin-bottom: 6px; }
    .service-desc { font-size: 0.82rem; line-height: 1.6; color: var(--text-muted); }

    /* PRICING */
    .pricing-box {
      background: var(--bg-glass); border: 1px solid var(--border-gold);
      padding: 40px; text-align: center; position: relative; overflow: hidden;
    }
    .pricing-box::before {
      content: ''; position: absolute; top: 0; left: 20%; right: 20%; height: 2px;
      background: linear-gradient(90deg, transparent, var(--emerald), transparent);
    }
    .pricing-tag {
      font-family: 'JetBrains Mono', monospace; font-size: 0.62rem; letter-spacing: 0.16em;
      text-transform: uppercase; color: var(--emerald); margin-bottom: 16px;
    }
    .pricing-numbers { display: flex; align-items: baseline; justify-content: center; gap: 24px; flex-wrap: wrap; margin-bottom: 20px; }
    .price-block { text-align: center; }
    .price-amount { font-family: 'Bebas Neue', sans-serif; font-size: 3.2rem; color: var(--text-primary); line-height: 1; }
    .price-amount sup { font-size: 1.3rem; vertical-align: super; color: var(--text-muted); }
    .price-label { font-family: 'JetBrains Mono', monospace; font-size: 0.62rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-dim); margin-top: 6px; }
    .price-plus { font-family: 'Bebas Neue', sans-serif; font-size: 1.8rem; color: var(--text-dim); align-self: center; }
    .pricing-note {
      font-size: 0.88rem; color: var(--text-muted); line-height: 1.6; max-width: 460px; margin: 0 auto 28px;
    }
    .pricing-note strong { color: var(--emerald); }

    /* GUARANTEE STRIP */
    .trust-strip { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: var(--border-glass); border: 1px solid var(--border-glass); }
    .trust-item { background: var(--bg-deep); padding: 22px 18px; text-align: center; }
    .trust-icon { font-size: 1.3rem; margin-bottom: 8px; }
    .trust-text { font-family: 'JetBrains Mono', monospace; font-size: 0.62rem; letter-spacing: 0.05em; color: var(--text-muted); line-height: 1.5; }

    /* CALENDLY */
    .calendly-section { text-align: center; }
    .calendly-wrap {
      background: var(--bg-glass); border: 1px solid var(--border-gold-dim);
      padding: 48px 40px; max-width: 680px; margin: 0 auto; position: relative; overflow: hidden;
    }
    .calendly-wrap::before {
      content: ''; position: absolute; top: 0; left: 20%; right: 20%; height: 2px;
      background: linear-gradient(90deg, transparent, var(--emerald), transparent);
    }
    .calendly-headline { font-family: 'Bebas Neue', sans-serif; font-size: 2.2rem; letter-spacing: 0.04em; margin-bottom: 12px; }
    .calendly-sub { font-size: 0.9rem; color: var(--text-muted); line-height: 1.6; margin-bottom: 28px; max-width: 440px; margin-left: auto; margin-right: auto; }
    .calendly-inline-widget { min-width: 280px; height: 700px; margin-bottom: 20px; }

    footer {
      border-top: 1px solid var(--border-glass); padding: 24px;
      max-width: 1080px; margin: 0 auto;
      display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 10px;
    }
    .footer-brand { font-family: 'JetBrains Mono', monospace; font-size: 0.62rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-dim); }
    .footer-links { display: flex; gap: 20px; }
    .footer-link { font-family: 'JetBrains Mono', monospace; font-size: 0.6rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-dim); text-decoration: none; }
    .footer-link:hover { color: var(--gold); }

    /* SCROLL REVEAL */
    .reveal { opacity: 0; transform: translateY(16px); transition: opacity 0.5s ease, transform 0.5s ease; }
    .reveal.visible { opacity: 1; transform: translateY(0); }

    /* TEXT ME WIDGET */
    .text-me-widget { position: fixed; bottom: 24px; right: 24px; z-index: 200; font-family: 'Syne', sans-serif; }
    .text-me-bubble {
      display: flex; align-items: center; justify-content: center;
      width: 56px; height: 56px; border-radius: 50%;
      background: linear-gradient(135deg, var(--gold), var(--orange));
      color: var(--btn-ink); font-size: 1.4rem; cursor: pointer; border: none;
      box-shadow: 0 8px 24px rgba(0,0,0,0.4);
      transition: transform 0.15s ease;
    }
    .text-me-bubble:hover { transform: scale(1.06); }
    .text-me-panel {
      display: none;
      position: absolute; bottom: 68px; right: 0;
      width: 250px; padding: 18px;
      background: var(--bg-deep); border: 1px solid var(--border-glass);
      border-radius: 12px; box-shadow: 0 12px 40px rgba(0,0,0,0.5);
    }
    .text-me-panel.open { display: block; }
    .text-me-title { font-family: 'Bebas Neue', sans-serif; font-size: 1.2rem; letter-spacing: 0.03em; margin-bottom: 6px; }
    .text-me-sub { font-size: 0.8rem; color: var(--text-muted); line-height: 1.5; margin-bottom: 14px; }
    .text-me-link {
      display: flex; align-items: center; justify-content: center; gap: 8px;
      font-family: 'JetBrains Mono', monospace; font-size: 0.78rem; font-weight: 600; letter-spacing: 0.04em;
      text-decoration: none; padding: 11px 14px; border-radius: 8px;
      background: linear-gradient(135deg, var(--gold), var(--orange)); color: var(--btn-ink);
    }

    @media (max-width: 760px) {
      .gbp-compare { grid-template-columns: 1fr; }
      .service-grid { grid-template-columns: 1fr; }
      .trust-strip { grid-template-columns: 1fr; }
      .pricing-numbers { flex-direction: column; gap: 8px; }
      .price-plus { display: none; }
    }

    @media (max-width: 560px) {
      .hero-actions { flex-direction: column; align-items: center; }
    }
  </style>
</head>

<body>
  <div class="bg-layer">
    <div class="bg-grid"></div>
    <div class="bg-orbs"></div>
    <div class="bg-scanlines"></div>
  </div>

  <nav>
    <div class="nav-inner">
      <a href="/" class="nav-logo"><img src="/logo.jpg" alt="ExpatBuildr" />ExpatBuildr</a>
      <div class="nav-right">
        <button type="button" class="theme-toggle" id="themeToggle" aria-label="Toggle dark mode">🌙</button>
        <a href="#book" class="nav-cta">Book a Call →</a>
      </div>
    </div>
  </nav>

  <main class="page">

    <!-- HERO -->
    <section class="hero" style="border-top: none;">
      <div class="hero-eyebrow">Google Business Profile</div>
      <h1 class="hero-headline">
        <span class="hl-white">If you're not on Google,</span><br />
        <span class="hl-gold">you don't exist to customers.</span>
      </h1>
      <p class="hero-sub">
        When someone searches your business name — or searches for what you do, near them — <strong>Google is the first thing they see.</strong> No listing, no photos, no reviews showing up means they call your competitor instead. We set it up, manage it, and keep it working every month.
      </p>
      <div class="hero-actions">
        <a href="#book" class="btn-primary">Book a Free 15-Min Call →</a>
        <a href="#pricing" class="btn-secondary">See Pricing</a>
      </div>
    </section>

    <!-- GBP COMPARISON -->
    <section>
      <div class="section-eyebrow">What this actually looks like</div>
      <h2 class="section-headline">Invisible vs.<br /><em>impossible to miss.</em></h2>

      <div class="gbp-compare reveal">
        <div class="gbp-card bad">
          <div class="gbp-head"><span>Search Result — No Profile</span></div>
          <div class="gbp-body-bad">
            <div class="not-found-icon">✕</div>
            <p class="not-found-text">
              <strong>No listing found.</strong><br />
              No map pin, no hours, no reviews, no photos.<br />
              Customers search — and find your competitor instead.
            </p>
          </div>
          <ul class="compare-flaws">
            <li>Doesn't appear in the local map pack</li>
            <li>No reviews visible = no trust signal</li>
            <li>No hours, address, or phone shown</li>
            <li>Zero visibility for "near me" searches</li>
          </ul>
        </div>

        <div class="gbp-card good">
          <div class="gbp-head"><span>Search Result — Fully Managed</span></div>
          <div class="gbp-body-good">
            <div class="gbp-biz-name">Your Business Name</div>
            <div class="gbp-stars">★★★★★ <span>4.9 (127)</span></div>
            <div class="gbp-meta">Local Service · <span class="gbp-open">Open Now</span> · 4.2 mi</div>
            <div class="gbp-photo-strip"><div></div><div></div><div></div><div></div></div>
            <div class="gbp-actions"><span>Call</span><span>Directions</span><span>Website</span></div>
            <div class="gbp-review">
              <div class="gbp-review-head"><span class="gbp-review-name">— Recent Review</span><span style="color:var(--gold); font-size:0.65rem;">★★★★★</span></div>
              <div class="gbp-review-reply"><strong>Owner replied:</strong> "Thanks so much for the kind words!"</div>
            </div>
          </div>
          <ul class="compare-flaws">
            <li>Shows up in the map pack + local search</li>
            <li>Reviews visible, replied to promptly</li>
            <li>Fresh photos signal an active business</li>
            <li>One tap to call, get directions, or visit site</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- WHAT WE DO -->
    <section>
