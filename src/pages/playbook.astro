---
import Pixels from '../components/GalaxyPixels.astro';
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
<title>The Philippines Arbitrage Playbook — Free Download</title>
<Pixels page="newsletter-landing" magnet="philippines-arbitrage-playbook" source="playbook" />
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --ink:#111118; --ink-soft:#444455; --ink-mute:#8888AA;
  --white:#FFFFFF; --cream:#FAFAF7; --amber:#F59E0B;
  --amber-lt:#FEF3C7; --amber-dk:#B45309; --border:#E8E8F0;
  --green:#16A34A; --green-lt:#DCFCE7;
}
body { font-family:'Inter',sans-serif; background:var(--white); color:var(--ink); line-height:1.6; }

.capture-nav { padding:20px 24px; border-bottom:1px solid var(--border); display:flex; align-items:center; justify-content:center; }
.capture-logo { font-family:'Syne',sans-serif; font-weight:800; font-size:16px; color:var(--ink); display:flex; align-items:center; gap:6px; text-decoration:none; }
.capture-logo-img { width:24px; height:24px; border-radius:50%; object-fit:cover; }

.capture-hero { max-width:680px; margin:0 auto; padding:56px 24px 64px; text-align:center; }
.capture-eyebrow { display:inline-flex; align-items:center; gap:6px; background:var(--amber-lt); color:var(--amber-dk); font-size:11px; font-weight:700; letter-spacing:.1em; text-transform:uppercase; padding:5px 14px; border-radius:100px; margin-bottom:28px; }
.capture-hero h1 { font-family:'Syne',sans-serif; font-size:clamp(28px,5vw,48px); font-weight:800; line-height:1.1; letter-spacing:-.02em; margin-bottom:20px; }
.capture-hero h1 em { font-style:normal; color:var(--amber); }
.capture-hero .sub { font-size:17px; color:var(--ink-soft); max-width:520px; margin:0 auto 12px; font-weight:400; line-height:1.6; }
.capture-hero .sub-small { font-size:14px; color:var(--ink-mute); margin-bottom:40px; }

.proof-strip { display:flex; align-items:center; justify-content:center; gap:6px; margin-bottom:40px; flex-wrap:wrap; }
.proof-avatars { display:flex; }
.proof-avatar { width:32px; height:32px; border-radius:50%; border:2px solid var(--white); background:linear-gradient(135deg,#f59e0b,#ef4444); margin-left:-8px; font-size:14px; display:flex; align-items:center; justify-content:center; color:white; font-weight:700; }
.proof-avatar:first-child { margin-left:0; }
.proof-text { font-size:13px; color:var(--ink-soft); }
.proof-text strong { color:var(--ink); }

.capture-form { background:var(--cream); border:1px solid var(--border); border-radius:20px; padding:36px 40px; max-width:480px; margin:0 auto 40px; }
.form-label { display:block; font-size:12px; font-weight:600; color:var(--ink-soft); letter-spacing:.06em; text-transform:uppercase; margin-bottom:8px; text-align:left; }
.form-input { width:100%; border:1px solid var(--border); border-radius:10px; padding:14px 16px; font-size:15px; font-family:'Inter',sans-serif; background:var(--white); color:var(--ink); outline:none; transition:border-color .15s; margin-bottom:12px; }
.form-input:focus { border-color:var(--amber); }
.btn-capture { width:100%; background:var(--amber); color:var(--ink); border:none; border-radius:10px; padding:16px; font-size:16px; font-weight:700; cursor:pointer; font-family:'Syne',sans-serif; transition:opacity .15s; letter-spacing:-.01em; margin-bottom:12px; }
.btn-capture:hover { opacity:.88; }
.form-privacy { font-size:11px; color:var(--ink-mute); text-align:center; }

.whats-inside { max-width:560px; margin:0 auto 48px; }
.whats-inside h3 { font-family:'Syne',sans-serif; font-size:16px; font-weight:700; margin-bottom:16px; text-align:center; color:var(--ink-soft); }
.inside-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; }
.inside-item { display:flex; align-items:flex-start; gap:10px; background:var(--white); border:1px solid var(--border); border-radius:12px; padding:14px; }
.inside-icon { font-size:20px; flex-shrink:0; line-height:1; }
.inside-text { font-size:13px; color:var(--ink-soft); line-height:1.4; }
.inside-text strong { color:var(--ink); display:block; font-size:13px; margin-bottom:2px; }

.pain-section { background:var(--ink); padding:56px 24px; }
.pain-inner { max-width:640px; margin:0 auto; text-align:center; }
.pain-inner h2 { font-family:'Syne',sans-serif; font-size:clamp(22px,4vw,34px); font-weight:800; color:var(--white); line-height:1.2; margin-bottom:32px; }
.pain-inner h2 span { color:var(--amber); }
.pain-list { display:flex; flex-direction:column; gap:12px; margin-bottom:36px; text-align:left; }
.pain-item { display:flex; align-items:flex-start; gap:12px; background:rgba(255,255,255,.06); border:1px solid rgba(255,255,255,.1); border-radius:12px; padding:16px; }
.pain-x { color:#ef4444; font-size:16px; font-weight:700; flex-shrink:0; margin-top:1px; }
.pain-text { font-size:14px; color:#ccccee; line-height:1.5; }
.pain-text strong { color:var(--white); }
.pain-cta { font-size:15px; color:#aaaacc; }
.pain-cta strong { color:var(--amber); }

.author-section { padding:56px 24px; background:var(--white); border-top:1px solid var(--border); }
.author-inner { max-width:560px; margin:0 auto; display:flex; align-items:flex-start; gap:24px; }
.author-avatar { width:72px; height:72px; border-radius:50%; flex-shrink:0; object-fit:cover; }
.author-name { font-family:'Syne',sans-serif; font-size:18px; font-weight:700; margin-bottom:4px; }
.author-handle { font-size:13px; color:var(--amber-dk); margin-bottom:10px; }
.author-handle a { color:var(--amber-dk); text-decoration:none; }
.author-handle a:hover { text-decoration:underline; }
.author-bio { font-size:14px; color:var(--ink-soft); line-height:1.6; }

@media(max-width:600px) { .inside-grid{grid-template-columns:1fr;} .capture-form{padding:24px 20px;} .author-inner{flex-direction:column;} }
</style>
</head>
<body>

<nav class="capture-nav">
  <a href="https://expatbuildr.com" class="capture-logo"><img src="/logo.jpg" alt="ExpatBuildr" class="capture-logo-img">ExpatBuildr</a>
</nav>

<section class="capture-hero">
  <div class="capture-eyebrow">🌏 Free Download</div>
  <h1>The exact move I made to<br><em>cut my expenses in half</em><br>without cutting my income</h1>
  <p class="sub">I lost $300K in crypto. Then I did the math, moved to the Philippines, and rebuilt everything — earning USD, spending pesos, saving more than I ever did in the US.</p>
  <p class="sub-small">This playbook is the exact system I used. Free. No pitch. Just the math and the moves.</p>

  <div class="proof-strip">
    <div class="proof-avatars">
      <div class="proof-avatar">J</div>
      <div class="proof-avatar">M</div>
      <div class="proof-avatar">R</div>
      <div class="proof-avatar">K</div>
      <div class="proof-avatar">+</div>
    </div>
    <p class="proof-text"><strong>2,400+ expats</strong> already downloaded this</p>
  </div>

  <div class="capture-form">
    <label class="form-label">Where should I send it?</label>
    <input class="form-input" type="text" id="cap-name" placeholder="First name">
    <input class="form-input" type="email" id="cap-email" placeholder="your@email.com">
    <button type="button" class="btn-capture" id="capSubmitBtn">Send Me the Playbook →</button>
    <p class="form-privacy">🔒 No spam. Unsubscribe anytime. Your email goes to Galaxy Arbitrage Weekly — free, weekly, worth reading.</p>
  </div>

  <div class="whats-inside">
    <h3>What's inside the free playbook</h3>
    <div class="inside-grid">
      <div class="inside-item"><div class="inside-icon">🧮</div><div class="inside-text"><strong>The Arbitrage Math</strong>Why $3,500/mo USD in the Philippines beats $8,000/mo in the US</div></div>
      <div class="inside-item"><div class="inside-icon">🏦</div><div class="inside-text"><strong>Banking Setup</strong>The exact accounts I use to receive USD and spend in pesos with zero fees</div></div>
      <div class="inside-item"><div class="inside-icon">✈️</div><div class="inside-text"><strong>The Move Checklist</strong>What to do before you leave, the week you arrive, and month one</div></div>
      <div class="inside-item"><div class="inside-icon">⚠️</div><div class="inside-text"><strong>47 Pitfalls</strong>Real mistakes that cost real money — documented so you skip every one</div></div>
      <div class="inside-item"><div class="inside-icon">💼</div><div class="inside-text"><strong>Remote Income Stack</strong>How to keep earning USD while living on pesos</div></div>
      <div class="inside-item"><div class="inside-icon">📍</div><div class="inside-text"><strong>City Breakdown</strong>Cebu vs Manila vs Davao — real cost of living by city</div></div>
    </div>
  </div>
</section>

<section class="pain-section">
  <div class="pain-inner">
    <h2>Sound familiar? <span>You're not alone.</span></h2>
    <div class="pain-list">
      <div class="pain-item"><span class="pain-x">✗</span><div class="pain-text"><strong>You're earning remotely but still paying American prices.</strong> The salary went remote. The rent didn't.</div></div>
      <div class="pain-item"><span class="pain-x">✗</span><div class="pain-text"><strong>You want to move abroad but have no idea where to start.</strong> Every blog says something different. Nobody gives you the actual numbers.</div></div>
      <div class="pain-item"><span class="pain-x">✗</span><div class="pain-text"><strong>You're already abroad but bleeding money with no system.</strong> No budget tracker. No clear picture of your arbitrage gap. Just vibes.</div></div>
    </div>
    <p class="pain-cta">The playbook fixes all three. And it's <strong>completely free.</strong></p>
  </div>
</section>

<section class="author-section">
  <div class="author-inner">
    <img class="author-avatar" src="/authors/galaxy.jpg" alt="Tony Long II">
    <div>
      <div class="author-name">Tony Long II</div>
      <div class="author-handle"><a href="https://x.com/expatbuildr" target="_blank" rel="noopener">@expatbuildr</a> · <a href="https://galaxyarbitrage.com" target="_blank" rel="noopener">GalaxyArbitrage.com</a> | <a href="https://expatbuildr.com" target="_blank" rel="noopener">ExpatBuildr.com</a></div>
      <p class="author-bio">Lost $300K in crypto. Did the math. Left the US and never looked back. Now building from Cebu, Philippines — earning USD, living on pesos, documenting every move in the Galaxy Arbitrage Weekly newsletter. This playbook is exactly what I wish someone had handed me on day one.</p>
    </div>
  </div>
</section>

<script>
async function handleSubmit() {
  const firstName = document.getElementById('cap-name').value.trim();
  const email = document.getElementById('cap-email').value.trim();
  if (!email || !email.includes('@')) {
    alert('Please enter a valid email address.');
    return;
  }

  const btn = document.getElementById('capSubmitBtn');
  btn.disabled = true;
  btn.textContent = 'Sending...';

  try {
    const res = await fetch('/api/galaxy-playbook-subscribe', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email, first_name: firstName }),
    });

    if (res.ok) {
      if (window.fireLeadEvent) window.fireLeadEvent();
      window.location.href = '/thankyou';
    } else {
      btn.disabled = false;
      btn.textContent = 'Send Me the Playbook →';
      alert('Something went wrong. Please try again.');
    }
  } catch (err) {
    btn.disabled = false;
    btn.textContent = 'Send Me the Playbook →';
    alert('Something went wrong. Please try again.');
  }
}

document.getElementById('capSubmitBtn').addEventListener('click', handleSubmit);
</script>
</body>
</html>
