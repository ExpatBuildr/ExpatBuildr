---
// /fixleaks — Service Close Page
// Context: Arrives here after receiving their audit report via email
const TEXT_NUMBER = "+13104618859";
const TEXT_NUMBER_DISPLAY = "(310) 461-8859";
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Fix the Leaks — ExpatBuildr Done-For-You Services</title>
  <meta name="description" content="You've seen the audit. Now let's fix it. Landing pages, email sequences, and full funnel architecture. Done for you in 3–7 days." />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Syne:wght@400;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

  <script is:inline>
    const theme = (() => {
      if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
        return localStorage.getItem('theme');
      }
      return 'light';
    })();
    if (theme === 'light') {
      document.documentElement.classList.remove('dark');
    } else {
      document.documentElement.classList.add('dark');
    }
    window.localStorage.setItem('theme', theme);
  </script>

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --gold: #3b82f6;
      --orange: #8b5cf6;
      --cyan: #22d3ee;
      --emerald: #0a9e5c;
      --red: #d92d4c;
      --bg-deep: #faf5ff;
      --bg-glass: rgba(2,6,23,0.035);
      --bg-glass-hover: rgba(2,6,23,0.06);
      --bg-featured: rgba(59,130,246,0.06);
      --border-glass: rgba(217,70,239,0.12);
      --border-gold: rgba(59,130,246,0.35);
      --border-gold-dim: rgba(59,130,246,0.16);
      --text-primary: #020617;
      --text-muted: #475569;
      --text-dim: #64748b;
      --nav-bg: rgba(250,245,255,0.92);
      --btn-ink: #ffffff;
      --mock-bg: #f3e8ff;
    }

    html.dark {
      --gold: #f5a623;
      --orange: #ff6b35;
      --cyan: #00d4ff;
      --emerald: #00e87a;
      --red: #ff2d55;
      --bg-deep: #060809;
      --bg-glass: rgba(255,255,255,0.028);
      --bg-glass-hover: rgba(255,255,255,0.05);
      --bg-featured: rgba(245,166,35,0.06);
      --border-glass: rgba(255,255,255,0.07);
      --border-gold: rgba(245,166,35,0.35);
      --border-gold-dim: rgba(245,166,35,0.15);
      --text-primary: #f0ece4;
      --text-muted: rgba(240,236,228,0.52);
      --text-dim: rgba(240,236,228,0.28);
      --nav-bg: rgba(6,8,9,0.9);
      --btn-ink: #060809;
      --mock-bg: #0d0f10;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg-deep);
      color: var(--text-primary);
      font-family: 'Syne', sans-serif;
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* ── BACKGROUND ── */
    .bg-layer {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
    }

    .bg-grid {
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(245,166,35,0.035) 1px, transparent 1px),
        linear-gradient(90deg, rgba(245,166,35,0.035) 1px, transparent 1px);
      background-size: 72px 72px;
    }

    .bg-orbs {
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 60% 40% at 15% 15%, rgba(255,107,53,0.08) 0%, transparent 55%),
        radial-gradient(ellipse 50% 35% at 85% 25%, rgba(245,166,35,0.07) 0%, transparent 50%),
        radial-gradient(ellipse 70% 50% at 50% 90%, rgba(0,212,255,0.04) 0%, transparent 55%);
    }

    .bg-scanlines {
      position: absolute;
      inset: 0;
      background: repeating-linear-gradient(
        0deg,
        transparent,
        transparent 2px,
        rgba(0,0,0,0.08) 2px,
        rgba(0,0,0,0.08) 4px
      );
      opacity: 0.4;
    }

    /* ── NAV ── */
    nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: var(--nav-bg);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border-glass);
    }

    .nav-inner {
      max-width: 1080px;
      margin: 0 auto;
      padding: 18px 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .nav-logo {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.4rem;
      letter-spacing: 0.12em;
      color: var(--gold);
      text-decoration: none;
    }
    .nav-logo img { width: 28px; height: 28px; border-radius: 6px; object-fit: cover; flex-shrink: 0; }

    .nav-right {
      display: flex;
      align-items: center;
      gap: 20px;
    }

    .theme-toggle {
      display: inline-flex; align-items: center; justify-content: center;
      width: 30px; height: 30px; border-radius: 50%;
      background: var(--bg-glass); border: 1px solid var(--border-glass);
      color: var(--text-muted); cursor: pointer; font-size: 0.85rem; flex-shrink: 0;
    }
    .theme-toggle:hover { border-color: var(--border-gold); color: var(--gold); }

    .nav-guarantee {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.6rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--emerald);
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .nav-cta {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.68rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      text-decoration: none;
      padding: 8px 16px;
      background: linear-gradient(135deg, var(--gold), var(--orange));
      color: var(--btn-ink);
      transition: filter 0.15s ease, transform 0.15s ease;
    }

    .nav-cta:hover { filter: brightness(1.1); transform: translateY(-1px); }

    /* ── PAGE ── */
    .page {
      position: relative;
      z-index: 1;
      max-width: 1080px;
      margin: 0 auto;
      padding: 0 24px;
    }

    /* ── HERO ── */
    .hero {
      padding: 80px 0 64px;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 64px;
      align-items: center;
    }

    .hero-left { animation: fadeUp 0.6s ease both; }

    .hero-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 24px;
      padding: 6px 12px;
      background: rgba(245,166,35,0.06);
      border: 1px solid var(--border-gold-dim);
    }

    .hero-eyebrow::before {
      content: '';
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: var(--gold);
      animation: blink 2s ease infinite;
    }

    @keyframes blink {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.2; }
    }

    .hero-headline {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(3.5rem, 6vw, 5.5rem);
      line-height: 0.93;
      letter-spacing: 0.02em;
      margin-bottom: 24px;
    }

    .hero-headline .hl-dim { display: block; color: var(--text-muted); }
    .hero-headline .hl-white { display: block; color: var(--text-primary); }
    .hero-headline .hl-gold { display: block; color: var(--gold); }

    .hero-sub {
      font-size: 1rem;
      line-height: 1.7;
      color: var(--text-muted);
      margin-bottom: 32px;
      max-width: 420px;
    }

    .hero-sub strong { color: var(--text-primary); }

    .hero-actions {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .btn-primary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.1rem;
      letter-spacing: 0.1em;
      text-decoration: none;
      padding: 16px 28px;
      background: linear-gradient(135deg, var(--gold), var(--orange));
      color: var(--btn-ink);
      position: relative;
      overflow: hidden;
      transition: transform 0.15s ease, box-shadow 0.15s ease;
    }

    .btn-primary::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(255,255,255,0.15), transparent);
      opacity: 0;
      transition: opacity 0.2s ease;
    }

    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 12px 40px rgba(245,166,35,0.3);
    }

    .btn-primary:hover::before { opacity: 1; }

    .btn-secondary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.72rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      text-decoration: none;
      padding: 13px 24px;
      background: transparent;
      border: 1px solid var(--border-glass);
      color: var(--text-muted);
      transition: border-color 0.2s ease, color 0.2s ease;
    }

    .btn-secondary:hover {
      border-color: var(--gold);
      color: var(--gold);
    }

    /* ── HERO RIGHT — AUDIT PREVIEW ── */
    .hero-right {
      animation: fadeUp 0.6s 0.15s ease both;
    }

    .audit-card {
      background: var(--bg-glass);
      border: 1px solid var(--border-glass);
      border-top: 2px solid var(--red);
      padding: 28px;
      position: relative;
    }

    .audit-card-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.6rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--red);
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .audit-card-label::before {
      content: '';
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: var(--red);
      animation: blink 1.5s ease infinite;
    }

    .audit-leak-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 10px;
      margin-bottom: 20px;
    }

    .audit-leak-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 10px 14px;
      background: rgba(255,45,85,0.04);
      border: 1px solid rgba(255,45,85,0.1);
    }

    .leak-severity {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.55rem;
      letter-spacing: 0.12em;
      padding: 2px 6px;
      flex-shrink: 0;
    }

    .leak-severity.high {
      background: rgba(255,45,85,0.15);
      border: 1px solid rgba(255,45,85,0.3);
      color: var(--red);
    }

    .leak-severity.med {
      background: rgba(255,166,35,0.1);
      border: 1px solid rgba(255,166,35,0.25);
      color: var(--gold);
    }

    .leak-text {
      font-size: 0.78rem;
      color: var(--text-muted);
      line-height: 1.4;
    }

    .audit-card-footer {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.6rem;
      letter-spacing: 0.1em;
      color: var(--text-dim);
      padding-top: 16px;
      border-top: 1px solid var(--border-glass);
    }

    /* ── SECTION BASE ── */
    section { padding: 72px 0; border-top: 1px solid var(--border-glass); }

    .section-eyebrow {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.62rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--text-dim);
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .section-eyebrow::after {
      content: '';
      flex: 0 0 40px;
      height: 1px;
      background: var(--border-glass);
    }

    .section-headline {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(2.4rem, 4vw, 3.5rem);
      line-height: 0.95;
      letter-spacing: 0.02em;
      margin-bottom: 48px;
    }

    .section-headline em {
      font-style: normal;
      color: var(--gold);
    }

    /* ── PRICING ── */
    .pricing-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: var(--border-glass);
      border: 1px solid var(--border-glass);
      margin-bottom: 24px;
    }

    .plan {
      background: var(--bg-deep);
      padding: 32px 24px;
      display: flex;
      flex-direction: column;
      position: relative;
      transition: background 0.2s ease;
    }

    .plan:hover { background: rgba(255,255,255,0.02); }

    .plan.featured {
      background: var(--bg-featured);
      border-left: 1px solid var(--border-gold-dim);
      border-right: 1px solid var(--border-gold-dim);
    }

    .plan.featured::before {
      content: 'MOST POPULAR';
      position: absolute;
      top: -1px;
      left: 50%;
      transform: translateX(-50%) translateY(-50%);
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.55rem;
      letter-spacing: 0.18em;
      background: linear-gradient(135deg, var(--gold), var(--orange));
      color: var(--btn-ink);
      padding: 3px 12px;
      font-weight: 600;
      white-space: nowrap;
    }

    .plan-tier {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.58rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--text-dim);
      margin-bottom: 10px;
    }

    .plan-name {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.6rem;
      letter-spacing: 0.05em;
      line-height: 1.1;
      margin-bottom: 8px;
      color: var(--text-primary);
    }

    .plan-tagline {
      font-size: 0.8rem;
      line-height: 1.55;
      color: var(--text-muted);
      margin-bottom: 20px;
      padding-bottom: 20px;
      border-bottom: 1px solid var(--border-glass);
      flex: 0;
    }

    .plan-price-wrap {
      margin-bottom: 8px;
    }

    .plan-price {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 3rem;
      letter-spacing: 0.02em;
      color: var(--text-primary);
      line-height: 1;
    }

    .plan-price sup {
      font-size: 1.2rem;
      vertical-align: super;
      color: var(--text-muted);
    }

    .plan-delivery {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.58rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--text-dim);
      margin-bottom: 20px;
    }

    .plan-features {
      list-style: none;
      flex: 1;
      margin-bottom: 24px;
      display: flex;
      flex-direction: column;
      gap: 0;
    }

    .plan-features li {
      font-size: 0.8rem;
      color: var(--text-muted);
      padding: 9px 0;
      border-bottom: 1px solid var(--border-glass);
      display: flex;
      align-items: flex-start;
      gap: 10px;
      line-height: 1.5;
    }

    .plan-features li::before {
      content: '✓';
      color: var(--emerald);
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.65rem;
      flex-shrink: 0;
      margin-top: 2px;
    }

    .plan-features li.inherit {
      color: var(--text-dim);
      font-style: italic;
    }

    .plan-features li.inherit::before { color: var(--text-dim); }

    .plan-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      text-decoration: none;
      padding: 13px 20px;
      transition: all 0.15s ease;
    }

    .plan-btn.default {
      background: transparent;
      border: 1px solid var(--border-glass);
      color: var(--text-muted);
    }

    .plan-btn.default:hover {
      border-color: var(--gold);
      color: var(--gold);
    }

    .plan-btn.featured-btn {
      background: linear-gradient(135deg, var(--gold), var(--orange));
      color: var(--btn-ink);
    }

    .plan-btn.featured-btn:hover {
      filter: brightness(1.1);
      transform: translateY(-1px);
      box-shadow: 0 8px 28px rgba(245,166,35,0.25);
    }

    /* ── EMPIRE ── */
    .empire-box {
      background: linear-gradient(180deg, var(--bg-featured), var(--bg-glass));
      border: 1px solid var(--border-gold);
      box-shadow: 0 0 0 1px var(--border-gold-dim), 0 24px 64px -24px rgba(245,166,35,0.25);
      padding: 40px;
      margin-top: 20px;
      position: relative;
      overflow: hidden;
    }

    .empire-box::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
      background: linear-gradient(90deg, transparent, var(--gold), var(--orange), var(--gold), transparent);
    }

    .empire-box::after {
      content: 'FLAGSHIP';
      position: absolute;
      top: -1px;
      right: 32px;
      transform: translateY(-50%);
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.58rem;
      letter-spacing: 0.2em;
      background: linear-gradient(135deg, var(--gold), var(--orange));
      color: var(--btn-ink);
      padding: 4px 14px;
      font-weight: 600;
      white-space: nowrap;
    }

    .empire-grid {
      display: grid;
      grid-template-columns: 1.4fr 1fr;
      gap: 40px;
      align-items: start;
    }

    .empire-tier {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.62rem;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 12px;
    }

    .empire-name {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 2.4rem;
      letter-spacing: 0.03em;
      line-height: 1;
      margin-bottom: 12px;
      color: var(--text-primary);
    }

    .empire-tagline {
      font-size: 0.92rem;
      line-height: 1.65;
      color: var(--text-muted);
      margin-bottom: 24px;
      max-width: 480px;
    }

    .empire-features {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0;
    }

    .empire-features li {
      font-size: 0.82rem;
      color: var(--text-muted);
      padding: 10px 0;
      border-bottom: 1px solid var(--border-glass);
      display: flex;
      align-items: flex-start;
      gap: 10px;
      line-height: 1.5;
    }

    .empire-features li:last-child { border-bottom: none; }

    .empire-features li::before {
      content: '✓';
      color: var(--emerald);
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.68rem;
      flex-shrink: 0;
      margin-top: 2px;
    }

    .empire-features li.inherit {
      color: var(--text-dim);
      font-style: italic;
    }

    .empire-features li.inherit::before { color: var(--text-dim); }

    .empire-pricing {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      padding-left: 40px;
      border-left: 1px solid var(--border-glass);
    }

    .empire-price {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 3.6rem;
      letter-spacing: 0.02em;
      color: var(--gold);
      line-height: 1;
      margin-bottom: 6px;
    }

    .empire-price sup { font-size: 1.3rem; vertical-align: super; }

    .empire-delivery {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.6rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--text-dim);
      margin-bottom: 24px;
    }

    .empire-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.1rem;
      letter-spacing: 0.08em;
      text-decoration: none;
      padding: 16px 20px;
      background: linear-gradient(135deg, var(--gold), var(--orange));
      color: var(--btn-ink);
      transition: transform 0.15s ease, box-shadow 0.15s ease;
    }

    .empire-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 32px rgba(245,166,35,0.3);
    }

    .empire-note {
      margin-top: 16px;
      font-size: 0.72rem;
      line-height: 1.5;
      color: var(--text-dim);
    }

    /* ── PROCESS ── */
    .process-steps {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: var(--border-glass);
      border: 1px solid var(--border-glass);
    }

    .proc-step {
      background: var(--bg-deep);
      padding: 32px 24px;
      position: relative;
      overflow: hidden;
      transition: background 0.2s ease;
    }

    .proc-step:hover { background: rgba(255,255,255,0.02); }

    .proc-step::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 2px;
      background: linear-gradient(90deg, var(--gold), transparent);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.3s ease;
    }

    .proc-step:hover::after { transform: scaleX(1); }

    .step-num {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 4rem;
      letter-spacing: 0.05em;
      line-height: 1;
