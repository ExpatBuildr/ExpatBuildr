  <script>
    const observer = new IntersectionObserver(
      entries => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
      { threshold: 0.08 }
    );
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    const textMeBubble = document.getElementById('textMeBubble');
    const textMePanel = document.getElementById('textMePanel');
    if (textMeBubble && textMePanel) {
      textMeBubble.addEventListener('click', () => {
        textMePanel.classList.toggle('open');
      });
      document.addEventListener('click', (e) => {
        if (!textMePanel.contains(e.target) && !textMeBubble.contains(e.target)) {
          textMePanel.classList.remove('open');
        }
      });
    }

    const toggleBtn = document.getElementById('themeToggle');
    if (toggleBtn) {
      const syncIcon = () => {
        toggleBtn.textContent = document.documentElement.classList.contains('dark') ? '☀️' : '🌙';
      };
      syncIcon();
      toggleBtn.addEventListener('click', () => {
        document.documentElement.classList.toggle('dark');
        const isDark = document.documentElement.classList.contains('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
        syncIcon();
      });
    }
  </script>

