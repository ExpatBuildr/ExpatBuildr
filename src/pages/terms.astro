---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

export const prerender = true;

const title = "Terms of Service | ExpatBuildr";
const description = "The rules of the game for the Remote Work Sniper ecosystem.";
---

<Layout 
    title={title}
    description={description}
>
    <!-- Main Content -->
    <div class="max-w-4xl mx-auto py-12 px-6">
        <header class="mb-16 reveal-on-scroll">
            <p class="text-[10px] font-mono uppercase tracking-[0.4em] text-accent-blue mb-4">
                Institutional / Documentation / Legal
            </p>
            <h1 class="text-5xl md:text-8xl font-black font-display tracking-tighter leading-none mb-6 text-slate-900 dark:text-white uppercase">
                TERMS OF<br/>
                <span class="text-slate-900/20 dark:text-white/20">SERVICE.</span>
            </h1>
            <p class="text-slate-500 font-mono text-[10px] uppercase tracking-widest">Initial Release Protocol: April 10, 2026</p>
        </header>

        <div class="prose">
            
            <section class="space-y-4">
                <h2 class="text-2xl font-black uppercase tracking-tight pb-2 border-b-2 border-slate-900/10 dark:border-white/10">01 · Acceptance of Terms</h2>
                <p>
                    By accessing ExpatBuildr.com or purchasing the "Remote Work Sniper" list, you agree to be bound by these Terms of Service. If you do not agree, please do not use our services.
                </p>
            </section>

            <section class="space-y-4">
                <h2 class="text-2xl font-black uppercase tracking-tight pb-2 border-b-2 border-slate-900/10 dark:border-white/10">02 · Digital Product Access</h2>
                <p>
                    The "US Remote Jobs List" is a digital product delivered via PDF and Notion. Upon successful payment of the one-time $50 fee, you are granted a non-exclusive, non-transferable lifetime license to access the list for personal use only.
                </p>
                <div class="bg-accent-blue/5 p-6 rounded-2xl border-l-4 border-accent-blue my-6">
                    <p class="font-bold text-slate-900 dark:text-white uppercase text-xs tracking-widest mb-0">
                        Sharing, reselling, or redistributing the list or Notion board access is strictly prohibited and will result in permanent termination of your access without refund.
                    </p>
                </div>
            </section>

            <section class="space-y-4">
                <h2 class="text-2xl font-black uppercase tracking-tight pb-2 border-b-2 border-slate-900/10 dark:border-white/10">03 · Refund Policy</h2>
                <p>
                    Due to the nature of digital products, all sales are final. However, we offer a "Performance Guarantee": If you apply to at least 5 jobs from the list within 30 days and receive zero responses, we will provide a one-on-one list refresh or a 50% refund at our discretion.
                </p>
            </section>

            <section class="space-y-4">
                <h2 class="text-2xl font-black uppercase tracking-tight pb-2 border-b-2 border-slate-900/10 dark:border-white/10">04 · Limitation of Liability</h2>
                <p>
                    ExpatBuildr provides job listings for informational purposes. We are not an employer or a recruitment agency. We do not guarantee employment or specific salary outcomes. Users are responsible for their own due diligence during the application process.
                </p>
            </section>

            <section class="space-y-4">
                <h2 class="text-2xl font-black uppercase tracking-tight pb-2 border-b-2 border-slate-900/10 dark:border-white/10">05 · Modifications</h2>
                <p>
                    We reserve the right to modify these terms at any time. Continued use of the service after modifications constitutes acceptance of the new terms.
                </p>
            </section>

        </div>

        <div class="mt-24 pt-8 border-t border-slate-900/10 dark:border-white/10 flex justify-between items-center text-[10px] font-mono text-slate-500 uppercase tracking-widest">
            <span>© {new Date().getFullYear()} ExpatBuildr</span>
            <a href="/privacy" class="hover:text-accent-blue transition-colors">Go to Privacy Policy →</a>
        </div>
    </div>
</Layout>
