---
// /meet-tony — Founder Credibility Page
// Context: Sent via email alongside the audit after a cold call.
// Job: build trust in Tony, then route to /fixleaks (packages) or a booked call.
// This page does NOT re-pitch the free audit — that ask is already done.
export const prerender = true;
const CALENDLY_URL = "https://calendly.com/expatbuildr/fixmyleaks";
const LINKEDIN_URL = "https://www.linkedin.com/in/expatbuildr/"; // matches the link used site-wide (Layout.astro, index.astro)
const TEXT_NUMBER = "+13104618859";
const TEXT_NUMBER_DISPLAY = "(310) 461-8859";
const META_PIXEL_ID = import.meta.env.META_PIXEL_ID || '1480646753745240';
const GTAG_ID = import.meta.env.GTAG_ID;

const PAGE_TITLE = "Tony Long II — Founder of ExpatBuildr | Meet the Builder Behind Your Audit";
const PAGE_DESCRIPTION = "Meet Tony Long II, founder of ExpatBuildr — an American web developer based in Cebu, Philippines building high-converting landing pages and funnels for small businesses. See the story, process, and guarantee behind your free website audit.";
const PAGE_URL = "https://expatbuildr.com/meet-tony";
const OG_IMAGE_URL = "https://expatbuildr.com/meet-tony.jpg";

const PERSON_ID = `${PAGE_URL}#person`;

// Combined into a single @graph so the ProfilePage's mainEntity @id reference
// actually resolves to the Person node — split across separate <script> tags,
// Google's validator can't link them and flags mainEntity as an untyped stub.
const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": PERSON_ID,
      "name": "Tony Long II",
      "url": PAGE_URL,
      "image": OG_IMAGE_URL,
      "jobTitle": "Founder & Web Developer",
      "worksFor": {
        "@type": "Organization",
        "name": "ExpatBuildr",
        "url": "https://expatbuildr.com"
      },
      "description": "American founder and web developer based in Cebu, Philippines. Builds landing pages, funnels, and conversion systems for small businesses through ExpatBuildr.",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Cebu City",
        "addressCountry": "PH"
      },
      "sameAs": [
        "https://www.linkedin.com/in/expatbuildr/",
        "https://x.com/expatbuildr"
      ]
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://expatbuildr.com/" },
        { "@type": "ListItem", "position": 2, "name": "Meet Tony", "item": PAGE_URL }
      ]
    },
    {
      "@type": "ProfilePage",
      "name": PAGE_TITLE,
      "description": PAGE_DESCRIPTION,
      "url": PAGE_URL,
      "mainEntity": { "@id": PERSON_ID },
      "primaryImageOfPage": OG_IMAGE_URL,
      "isPartOf": {
        "@type": "WebSite",
        "name": "ExpatBuildr",
        "url": "https://expatbuildr.com"
      }
    }
  ]
};
---

<!DOCTYPE html>
<html lang="en" prefix="og: https://ogp.me/ns# profile: https://ogp.me/ns/profile#">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{PAGE_TITLE}</title>
  <meta name="description" content={PAGE_DESCRIPTION} />
  <meta name="author" content="Tony Long II" />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={PAGE_URL} />
  <meta property="og:title" content="Tony Long II — Founder of ExpatBuildr" />
  <meta property="og:description" content={PAGE_DESCRIPTION} />
  <meta property="og:image" content={OG_IMAGE_URL} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="Tony Long II's beachfront balcony office in Cebu, Philippines, with a laptop showing an ExpatBuildr website design" />
  <meta property="og:url" content={PAGE_URL} />
  <meta property="og:type" content="profile" />
  <meta property="og:locale" content="en_US" />
  <meta property="og:site_name" content="ExpatBuildr" />
  <meta property="profile:first_name" content="Tony" />
  <meta property="profile:last_name" content="Long" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@expatbuildr" />
  <meta name="twitter:title" content="Tony Long II — Founder of ExpatBuildr" />
  <meta name="twitter:description" content={PAGE_DESCRIPTION} />
  <meta name="twitter:image" content={OG_IMAGE_URL} />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Syne:wght@400;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <script is:inline>
    const theme = (() => {
      if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
        return localStorage.getItem('theme');
      }
      return 'light';
    })();
    if (theme === 'light') {
      document.documentElement.classList.remove('dark');
    } else {
      document.documentElement.classList.add('dark');
    }
    window.localStorage.setItem('theme', theme);
  </script>

  <!-- Meta Pixel -->
  <script is:inline define:vars={{ META_PIXEL_ID }}>
    !function(f,b,e,v,n,t,s)
    {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
    n.callMethod.apply(n,arguments):n.queue.push(arguments)};
    if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
    n.queue=[];t=b.createElement(e);t.async=!0;
    t.src=v;s=b.getElementsByTagName(e)[0];
    s.parentNode.insertBefore(t,s)}(window,document,'script',
    'https://connect.facebook.net/en_US/fbevents.js');
    fbq('init', META_PIXEL_ID);
    fbq('track', 'PageView');
    fbq('track', 'ViewContent', {
      content_name: 'Meet Tony Page',
      content_category: 'Founder Credibility',
    });
  </script>
  <noscript>
    <img height="1" width="1" style="display:none" alt=""
      src={`https://www.facebook.com/tr?id=${META_PIXEL_ID}&ev=PageView&noscript=1`} />
  </noscript>

  {GTAG_ID && (
    <>
      <script is:inline define:vars={{ GTAG_ID }} async src={`https://www.googletagmanager.com/gtag/js?id=${GTAG_ID}`}></script>
      <script is:inline define:vars={{ GTAG_ID }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', GTAG_ID);
        gtag('event', 'meet_tony_view');
      </script>
    </>
  )}

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --gold: #3b82f6;
      --orange: #8b5cf6;
      --cyan: #22d3ee;
      --emerald: #0a9e5c;
      --red: #d92d4c;
      --bg-deep: #faf5ff;
      --bg-glass: rgba(2,6,23,0.035);
      --bg-glass-hover: rgba(2,6,23,0.06);
      --border-glass: rgba(217,70,239,0.12);
      --border-gold: rgba(59,130,246,0.35);
      --border-gold-dim: rgba(59,130,246,0.16);
      --text-primary: #020617;
      --text-muted: #475569;
      --text-dim: #64748b;
      --nav-bg: rgba(250,245,255,0.92);
      --btn-ink: #ffffff;
      --mock-bg: #f3e8ff;
    }

    html.dark {
      --gold: #f5a623;
      --orange: #ff6b35;
      --cyan: #00d4ff;
      --emerald: #00e87a;
      --red: #ff2d55;
      --bg-deep: #060809;
      --bg-glass: rgba(255,255,255,0.028);
      --bg-glass-hover: rgba(255,255,255,0.05);
      --border-glass: rgba(255,255,255,0.07);
      --border-gold: rgba(245,166,35,0.35);
      --border-gold-dim: rgba(245,166,35,0.15);
      --text-primary: #f0ece4;
      --text-muted: rgba(240,236,228,0.52);
      --text-dim: rgba(240,236,228,0.28);
      --nav-bg: rgba(6,8,9,0.9);
      --btn-ink: #060809;
      --mock-bg: #0d0f10;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg-deep);
      color: var(--text-primary);
      font-family: 'Syne', sans-serif;
      min-height: 100vh;
      overflow-x: hidden;
    }

    .bg-layer { position: fixed; inset: 0; z-index: 0; pointer-events: none; }
    .bg-grid {
      position: absolute; inset: 0;
      background-image:
        linear-gradient(rgba(200,135,26,0.05) 1px, transparent 1px),
        linear-gradient(90deg, rgba(200,135,26,0.05) 1px, transparent 1px);
      background-size: 72px 72px;
    }
    .bg-orbs {
      position: absolute; inset: 0;
      background:
        radial-gradient(ellipse 55% 40% at 10% 10%, rgba(217,122,63,0.05) 0%, transparent 55%),
        radial-gradient(ellipse 50% 35% at 90% 20%, rgba(200,135,26,0.04) 0%, transparent 50%),
        radial-gradient(ellipse 60% 45% at 50% 95%, rgba(0,135,179,0.03) 0%, transparent 55%);
    }

    /* NAV */
    nav {
      position: sticky; top: 0; z-index: 100;
      background: var(--nav-bg);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border-glass);
    }
    .nav-inner {
      max-width: 920px; margin: 0 auto; padding: 16px 24px;
      display: flex; align-items: center; gap: 14px; justify-content: space-between;
    }
    .theme-toggle {
      display: inline-flex; align-items: center; justify-content: center;
      width: 30px; height: 30px; border-radius: 50%;
      background: var(--bg-glass); border: 1px solid var(--border-glass);
      color: var(--text-muted); cursor: pointer; font-size: 0.85rem;
      flex-shrink: 0;
    }
    .theme-toggle:hover { border-color: var(--border-gold); color: var(--gold); }
    .nav-logo {
      display: inline-flex; align-items: center; gap: 8px;
      font-family: 'Bebas Neue', sans-serif; font-size: 1.3rem; letter-spacing: 0.12em; color: var(--gold); text-decoration: none;
    }
    .nav-logo img { width: 28px; height: 28px; border-radius: 6px; object-fit: cover; flex-shrink: 0; }
    .nav-clock {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.6rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--text-dim);
      display: flex; align-items: center; gap: 6px;
    }
    .nav-clock::before {
      content: ''; width: 5px; height: 5px; border-radius: 50%;
      background: var(--emerald);
      animation: blink 2s ease infinite;
    }
    @keyframes blink { 0%,100% { opacity: 1; } 50% { opacity: 0.3; } }
    .nav-cta {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.65rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase;
      text-decoration: none; padding: 9px 16px;
      background: linear-gradient(135deg, var(--gold), var(--orange));
      color: var(--btn-ink);
    }

    .page { position: relative; z-index: 1; max-width: 920px; margin: 0 auto; padding: 0 24px; }

    /* HERO */
    .hero { padding: 72px 0 56px; display: grid; grid-template-columns: auto 1fr; gap: 40px; align-items: center; }
    .hero-photo {
      width: 132px; height: 132px; border-radius: 50%;
      object-fit: cover;
      border: 2px solid var(--border-gold);
      flex-shrink: 0;
    }
    .hero-eyebrow {
      display: inline-flex; align-items: center; gap: 8px;
      font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; letter-spacing: 0.18em;
      text-transform: uppercase; color: var(--emerald); margin-bottom: 14px;
    }
    .hero-eyebrow::before { content: '✓'; }
    .hero-name {
      font-family: 'Bebas Neue', sans-serif; font-size: clamp(2.6rem, 5vw, 3.6rem);
      letter-spacing: 0.02em; line-height: 0.95; margin-bottom: 8px; color: var(--text-primary);
    }
    .hero-role {
      font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; letter-spacing: 0.08em;
      color: var(--gold); text-transform: uppercase; margin-bottom: 14px;
    }
    .hero-sub { font-size: 0.95rem; line-height: 1.65; color: var(--text-muted); max-width: 480px; }
    .hero-sub strong { color: var(--text-primary); }

    section { padding: 56px 0; border-top: 1px solid var(--border-glass); }
    .section-eyebrow {
      font-family: 'JetBrains Mono', monospace; font-size: 0.6rem; letter-spacing: 0.2em;
      text-transform: uppercase; color: var(--text-dim); margin-bottom: 14px;
      display: flex; align-items: center; gap: 12px;
    }
    .section-eyebrow::after { content: ''; flex: 0 0 40px; height: 1px; background: var(--border-glass); }
    .section-headline {
      font-family: 'Bebas Neue', sans-serif; font-size: clamp(2rem, 3.4vw, 2.8rem);
      line-height: 1; letter-spacing: 0.02em; margin-bottom: 28px;
    }
    .section-headline em { font-style: normal; color: var(--gold); }

    /* STORY */
    .story-text { font-size: 0.95rem; line-height: 1.75; color: var(--text-muted); max-width: 640px; }
    .story-text + .story-text { margin-top: 16px; }
    .story-text strong { color: var(--text-primary); }

    .linkedin-strip {
      margin-top: 28px; display: flex; align-items: center; gap: 14px;
      padding: 14px 18px; background: var(--bg-glass); border: 1px solid var(--border-glass);
      width: fit-content;
    }
    .linkedin-strip a {
      font-family: 'JetBrains Mono', monospace; font-size: 0.68rem; letter-spacing: 0.08em;
      text-transform: uppercase; color: var(--cyan); text-decoration: none;
    }
    .linkedin-strip a:hover { text-decoration: underline; }

    /* STACK BADGES */
    .stack-row { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 24px; }
    .stack-badge {
      font-family: 'JetBrains Mono', monospace; font-size: 0.62rem; letter-spacing: 0.08em;
      padding: 7px 12px; background: var(--bg-glass); border: 1px solid var(--border-glass);
      color: var(--text-muted); text-transform: uppercase;
    }

    /* PROCESS */
    .process-steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: var(--border-glass); border: 1px solid var(--border-glass); }
    .proc-step { background: var(--bg-deep); padding: 26px 22px; }
    .step-num { font-family: 'Bebas Neue', sans-serif; font-size: 3.2rem; line-height: 1; color: rgba(245,166,35,0.1); margin-bottom: 12px; }
    .step-title { font-family: 'Syne', sans-serif; font-size: 0.95rem; font-weight: 700; margin-bottom: 6px; }
    .step-title em { font-style: normal; color: var(--gold); }
    .step-desc { font-size: 0.8rem; line-height: 1.6; color: var(--text-muted); }

    /* BAD VS GOOD COMPARISON */
    .compare-caption {
      font-family: 'JetBrains Mono', monospace; font-size: 0.62rem; letter-spacing: 0.05em;
      color: var(--text-dim); margin-bottom: 22px; line-height: 1.6; max-width: 560px;
      text-transform: none;
    }
    .compare-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 20px; }
    .compare-card { border-radius: 4px; overflow: hidden; border: 1px solid var(--border-glass); }
    .compare-card.bad { border-color: rgba(255,45,85,0.25); }
    .compare-card.good { border-color: rgba(0,232,122,0.3); }
    .compare-head {
      display: flex; align-items: center; justify-content: space-between;
      padding: 10px 14px;
      font-family: 'JetBrains Mono', monospace; font-size: 0.62rem; letter-spacing: 0.1em; text-transform: uppercase;
    }
    .compare-card.bad .compare-head { background: rgba(255,45,85,0.08); color: var(--red); }
    .compare-card.good .compare-head { background: rgba(0,232,122,0.08); color: var(--emerald); }
    .browser-dots { display: flex; gap: 4px; }
    .browser-dots span { width: 6px; height: 6px; border-radius: 50%; background: currentColor; opacity: 0.4; }

    .mock-screen { background: var(--mock-bg); padding: 18px; min-height: 240px; }
    .mock-line { height: 8px; border-radius: 2px; background: rgba(255,255,255,0.08); margin-bottom: 8px; }
    .mock-line.w60 { width: 60%; }
    .mock-line.w80 { width: 80%; }
    .mock-line.w40 { width: 40%; }
    .mock-line.w90 { width: 90%; }
    .mock-block { background: rgba(255,255,255,0.05); border-radius: 3px; margin-bottom: 10px; }

    .mock-bad .mock-line { background: rgba(255,45,85,0.18); }
    .mock-bad .mock-block { height: 46px; }
    .mock-bad .mock-btn {
      display: inline-block; font-size: 0.55rem; padding: 4px 8px; margin-top: 6px;
      color: var(--text-dim); border: 1px solid rgba(255,255,255,0.1); border-radius: 2px;
    }

    .mock-good .mock-hero-line { height: 16px; width: 85%; background: rgba(0,232,122,0.25); border-radius: 3px; margin-bottom: 10px; }
    .mock-good .mock-sub-line { height: 7px; width: 65%; background: rgba(255,255,255,0.1); border-radius: 2px; margin-bottom: 16px; }
    .mock-good .mock-cta {
      display: inline-block; font-family: 'JetBrains Mono', monospace; font-size: 0.6rem; letter-spacing: 0.08em;
      text-transform: uppercase; padding: 9px 16px; border-radius: 2px;
      background: linear-gradient(135deg, var(--gold), var(--orange)); color: var(--btn-ink); margin-bottom: 18px;
    }
    .mock-good .mock-block { height: 54px; background: rgba(0,212,255,0.06); border: 1px solid rgba(0,212,255,0.12); }

    .compare-flaws { padding: 14px 16px; }
    .compare-flaws li {
      list-style: none; display: flex; gap: 8px; align-items: flex-start;
      font-size: 0.76rem; line-height: 1.5; color: var(--text-muted); padding: 5px 0;
    }
    .compare-card.bad .compare-flaws li::before { content: '✕'; color: var(--red); flex-shrink: 0; font-size: 0.7rem; }
    .compare-card.good .compare-flaws li::before { content: '✓'; color: var(--emerald); flex-shrink: 0; font-size: 0.7rem; }

    /* NEXT STEPS BRIDGE */
    .next-steps {
      margin-top: 24px;
      background: var(--bg-glass);
      border: 1px solid var(--border-gold);
      padding: 26px 28px;
      position: relative;
      overflow: hidden;
    }
    .next-steps::before {
      content: '';
      position: absolute; top: 0; left: 15%; right: 15%; height: 2px;
      background: linear-gradient(90deg, transparent, var(--gold), transparent);
    }
    .next-steps-label {
      font-family: 'JetBrains Mono', monospace; font-size: 0.62rem; letter-spacing: 0.16em;
      text-transform: uppercase; color: var(--gold); margin-bottom: 10px;
    }
    .next-steps-text {
      font-size: 0.88rem; line-height: 1.65; color: var(--text-muted); max-width: 560px; margin-bottom: 18px;
    }
    .next-steps-text strong { color: var(--text-primary); }
    .next-steps-btns { display: flex; gap: 12px; flex-wrap: wrap; }

    /* FOUNDING CLIENT / PROOF PLACEHOLDER */
    .founding-box {
      background: var(--bg-glass); border: 1px solid var(--border-gold-dim);
      padding: 28px; margin-bottom: 20px;
    }
    .founding-tag {
      font-family: 'JetBrains Mono', monospace; font-size: 0.6rem; letter-spacing: 0.16em;
      text-transform: uppercase; color: var(--gold); margin-bottom: 10px;
    }
    .founding-text { font-size: 0.88rem; line-height: 1.7; color: var(--text-muted); max-width: 600px; }
    .founding-text strong { color: var(--text-primary); }

    .proof-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
    .proof-card {
      background: var(--bg-glass); border: 1px dashed var(--border-glass);
      padding: 20px 16px; text-align: center;
    }
    .proof-icon { font-size: 1.4rem; margin-bottom: 10px; opacity: 0.4; }
    .proof-label {
      font-family: 'JetBrains Mono', monospace; font-size: 0.6rem; letter-spacing: 0.1em;
      text-transform: uppercase; color: var(--text-dim); line-height: 1.5;
    }

    /* GUARANTEE */
    .guarantee-box {
      background: var(--bg-glass); border: 1px solid rgba(0,232,122,0.15);
      padding: 28px; display: flex; gap: 20px; align-items: flex-start;
    }
    .guarantee-icon { font-size: 2rem; flex-shrink: 0; }
    .guarantee-title { font-family: 'Bebas Neue', sans-serif; font-size: 1.4rem; letter-spacing: 0.05em; color: var(--emerald); margin-bottom: 6px; }
    .guarantee-text { font-size: 0.85rem; line-height: 1.6; color: var(--text-muted); }
    .guarantee-text strong { color: var(--text-primary); }

    /* FINAL CTA */
    .final-cta { text-align: center; padding: 64px 0; }
    .final-headline {
      font-family: 'Bebas Neue', sans-serif; font-size: clamp(2.2rem, 4.5vw, 3.4rem);
      letter-spacing: 0.02em; line-height: 0.95; margin-bottom: 16px;
    }
    .final-headline .fh-gold { color: var(--gold); }
    .final-sub { font-size: 0.92rem; color: var(--text-muted); line-height: 1.6; max-width: 460px; margin: 0 auto 30px; }
    .final-btns { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
    .btn-primary {
      display: inline-flex; align-items: center; justify-content: center; gap: 8px;
      font-family: 'Bebas Neue', sans-serif; font-size: 1.05rem; letter-spacing: 0.1em;
      text-decoration: none; padding: 15px 26px;
      background: linear-gradient(135deg, var(--gold), var(--orange)); color: var(--btn-ink);
      transition: transform 0.15s ease, box-shadow 0.15s ease;
    }
    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 10px 36px rgba(245,166,35,0.28); }
    .btn-secondary {
      display: inline-flex; align-items: center; justify-content: center; gap: 8px;
      font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; letter-spacing: 0.1em; text-transform: uppercase;
      text-decoration: none; padding: 13px 24px; background: transparent;
      border: 1px solid var(--border-glass); color: var(--text-muted);
      transition: border-color 0.2s ease, color 0.2s ease;
    }
    .btn-secondary:hover { border-color: var(--gold); color: var(--gold); }

    footer {
      border-top: 1px solid var(--border-glass); padding: 22px 24px;
      max-width: 920px; margin: 0 auto;
      display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 10px;
    }
    .footer-brand { font-family: 'JetBrains Mono', monospace; font-size: 0.6rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-dim); }
    .footer-links { display: flex; gap: 18px; }
    .footer-link { font-family: 'JetBrains Mono', monospace; font-size: 0.58rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-dim); text-decoration: none; }
    .footer-link:hover { color: var(--gold); }

    @media (max-width: 640px) {
      .hero { grid-template-columns: 1fr; text-align: center; justify-items: center; }
      .process-steps { grid-template-columns: 1fr; }
      .proof-grid { grid-template-columns: 1fr; }
      .guarantee-box { flex-direction: column; }
      .linkedin-strip { margin-left: auto; margin-right: auto; }
    }

    /* TEXT ME WIDGET */
    .text-me-widget { position: fixed; bottom: 24px; right: 24px; z-index: 200; font-family: 'Syne', sans-serif; }
    .text-me-bubble {
      display: flex; align-items: center; justify-content: center;
      width: 56px; height: 56px; border-radius: 50%;
      background: linear-gradient(135deg, var(--gold), var(--orange));
      color: var(--btn-ink); font-size: 1.4rem; cursor: pointer; border: none;
      box-shadow: 0 8px 24px rgba(0,0,0,0.18);
      transition: transform 0.15s ease;
    }
    .text-me-bubble:hover { transform: scale(1.06); }
    .text-me-panel {
      display: none;
      position: absolute; bottom: 68px; right: 0;
      width: 250px; padding: 18px;
      background: var(--bg-deep); border: 1px solid var(--border-glass);
      border-radius: 12px; box-shadow: 0 12px 40px rgba(0,0,0,0.2);
    }
    .text-me-panel.open { display: block; }
    .text-me-title { font-family: 'Bebas Neue', sans-serif; font-size: 1.2rem; letter-spacing: 0.03em; margin-bottom: 6px; }
    .text-me-sub { font-size: 0.8rem; color: var(--text-muted); line-height: 1.5; margin-bottom: 14px; }
    .text-me-link {
      display: flex; align-items: center; justify-content: center; gap: 8px;
      font-family: 'JetBrains Mono', monospace; font-size: 0.78rem; font-weight: 600; letter-spacing: 0.04em;
      text-decoration: none; padding: 11px 14px; border-radius: 8px;
      background: linear-gradient(135deg, var(--gold), var(--orange)); color: var(--btn-ink);
    }
  </style>
</head>

<body>
  <div class="bg-layer">
    <div class="bg-grid"></div>
    <div class="bg-orbs"></div>
  </div>

  <nav>
    <div class="nav-inner">
      <a href="/" class="nav-logo"><img src="/logo.jpg" alt="ExpatBuildr" />ExpatBuildr</a>
      <div class="nav-clock" id="cebuClock">Cebu, PH — loading...</div>
      <button type="button" class="theme-toggle" id="themeToggle" aria-label="Toggle dark mode">🌙</button>
      <a href="/fixleaks#pricing" class="nav-cta">See Packages →</a>
    </div>
  </nav>

  <main class="page">

    <!-- HERO -->
    <section class="hero" style="border-top: none;">
      <img src="/authors/galaxy.jpg" alt="Tony Long II" class="hero-photo" />
      <div>
        <div class="hero-eyebrow">You already have your audit</div>
        <h1 class="hero-name">Tony Long II</h1>
        <div class="hero-role">Founder, ExpatBuildr</div>
        <p class="hero-sub">
          I'm the person who went through your website line by line. <strong>No agency, no account manager, no outsourced team</strong> — just me, building and fixing sites for local businesses, full time.
        </p>
      </div>
    </section>

    <!-- STORY -->
    <section>
      <div class="section-eyebrow">Who's building this</div>
      <h2 class="section-headline">American builder.<br /><em>Based in Cebu.</em></h2>
      <p class="story-text">
        I'm a founder based in Cebu, Philippines, running <strong>ExpatBuildr</strong> — I build landing pages, funnels, and conversion systems for small businesses whose websites are quietly costing them customers.
      </p>
      <p class="story-text">
        I do the audits myself. I write the copy myself. I build every page myself. When you work with me, you're not getting a project manager relaying your feedback to a team you'll never talk to — <strong>you're talking directly to the person doing the work.</strong>
      </p>
      <div class="linkedin-strip">
        <span style="font-size: 1.1rem;">in</span>
        <a href={LINKEDIN_URL} target="_blank" rel="noopener">Connect with me on LinkedIn →</a>
      </div>
      <div class="stack-row">
        <span class="stack-badge">Astro</span>
        <span class="stack-badge">Cloudflare</span>
        <span class="stack-badge">Stripe</span>
        <span class="stack-badge">Meta Ads</span>
        <span class="stack-badge">Conversion Copy</span>
        <span class="stack-badge">Email Systems</span>
      </div>
    </section>

    <!-- PROCESS -->
    <section>
      <div class="section-eyebrow">How this works</div>
      <h2 class="section-headline">From audit<br /><em>to launch.</em></h2>
      <div class="process-steps">
        <div class="proc-step">
          <div class="step-num">01</div>
          <div class="step-title">You <em>pick a package</em></div>
          <p class="step-desc">Based on the leaks in your audit, choose the fix that matches — starter page, growth bundle, or full funnel.</p>
        </div>
        <div class="proc-step">
          <div class="step-num">02</div>
          <div class="step-title">I <em>build it</em></div>
          <p class="step-desc">Copy, layout, pixels, and email sequence — built by me, not a subcontractor. You get updates as I go.</p>
        </div>
        <div class="proc-step">
          <div class="step-num">03</div>
          <div class="step-title">You <em>launch it</em></div>
          <p class="step-desc">Delivered live, tested, and ready for traffic. You own every file — no lock-in, no recurring platform fee.</p>
        </div>
      </div>
    </section>

    <!-- WHAT CONVERTS VS WHAT DOESN'T -->
    <section>
      <div class="section-eyebrow">What this actually looks like</div>
      <h2 class="section-headline">Design flaws vs.<br /><em>fixed on purpose.</em></h2>
      <p class="compare-caption">
        Illustrative comparison — not a real client site. This is the same pattern I look for in every audit, including yours.
      </p>

      <div class="compare-grid">
        <div class="compare-card bad">
          <div class="compare-head">
            <span>Typical Small Business Site</span>
            <span class="browser-dots"><span></span><span></span><span></span></span>
          </div>
          <div class="mock-screen mock-bad">
            <div class="mock-line w40"></div>
            <div class="mock-line w90"></div>
            <div class="mock-line w80"></div>
            <div class="mock-line w60"></div>
            <div class="mock-block"></div>
            <span class="mock-btn">contact us</span>
          </div>
          <ul class="compare-flaws">
            <li>No clear call-to-action above the fold</li>
            <li>Contact buried at the bottom of the page</li>
            <li>Wall of text, no visual hierarchy</li>
            <li>Same layout crammed onto mobile</li>
          </ul>
        </div>

        <div class="compare-card good">
          <div class="compare-head">
            <span>Rebuilt for Conversion</span>
            <span class="browser-dots"><span></span><span></span><span></span></span>
          </div>
          <div class="mock-screen mock-good">
            <div class="mock-hero-line"></div>
            <div class="mock-sub-line"></div>
            <span class="mock-cta">Book Now →</span>
            <div class="mock-block"></div>
          </div>
          <ul class="compare-flaws">
            <li>One clear headline, one clear next step</li>
            <li>CTA visible without scrolling</li>
            <li>Built mobile-first, not squeezed to fit</li>
            <li>Every element earns its place on the page</li>
          </ul>
        </div>
      </div>

      <div class="next-steps">
        <div class="next-steps-label">What Happens Next</div>
        <p class="next-steps-text">
          That's the exact gap I found in your audit. <strong>Here's what I'll do:</strong> rebuild your page using this same logic — one headline, one CTA, mobile-first, nothing competing for attention. Pick the package that matches what your site needs and I'll get started.
        </p>
        <div class="next-steps-btns">
          <a href="/fixleaks#pricing" class="btn-primary">See Packages & Pricing →</a>
        </div>
      </div>

      <div class="founding-box">
        <div class="founding-tag">Founding Client Positioning</div>
        <p class="founding-text">
          I'm early — you'd be one of my first official launch clients. That means <strong>your project gets my full, undivided attention</strong> — not a queue behind a dozen other retainer clients. Founding clients also lock in current pricing before it moves up as the book fills.
        </p>
      </div>
    </section>


    <!-- GUARANTEE -->
    <section>
      <div class="section-eyebrow">Guarantee</div>
      <h2 class="section-headline">If it's not right,<br /><em>I fix it.</em></h2>
      <div class="guarantee-box">
        <div class="guarantee-icon">🛡</div>
        <div>
          <div class="guarantee-title">2-Round Revision Guarantee</div>
          <p class="guarantee-text">Every project includes two rounds of revisions at no extra cost. If something's off, <strong>I fix it</strong> — no argument, no extra invoice.</p>
        </div>
      </div>
    </section>

    <!-- BOOK A CALL -->
    <section id="call" style="text-align: center;">
      <div class="section-eyebrow" style="justify-content: center;">Not sure which package?</div>
      <h2 class="section-headline" style="text-align: center;">Talk to me <em>first.</em></h2>
      <p class="final-sub" style="margin-bottom: 24px;">Tell me what you're building. I'll tell you exactly what you need — and what you don't. No pitch, no pressure.</p>

      <!-- Calendly inline widget begin -->
      <div class="calendly-inline-widget" data-url={CALENDLY_URL} style="min-width:320px;height:700px;"></div>
      <script is:inline type="text/javascript" src="https://assets.calendly.com/assets/external/widget.js" async></script>
      <!-- Calendly inline widget end -->

      <p style="font-family: 'JetBrains Mono', monospace; font-size: 0.6rem; letter-spacing: 0.12em; color: var(--text-dim); text-transform: uppercase;">
        Free · 15 minutes · No obligation
      </p>
    </section>

    <!-- FINAL CTA -->
    <div class="final-cta">
      <h2 class="final-headline">Ready to fix<br /><span class="fh-gold">what the audit found?</span></h2>
      <p class="final-sub">Pick your package directly, or book above if you want to talk it through first.</p>
      <div class="final-btns">
        <a href="/fixleaks#pricing" class="btn-primary">See Packages →</a>
      </div>
    </div>

  </main>

  <footer>
    <span class="footer-brand">ExpatBuildr · Built in the Philippines 🇵🇭</span>
    <nav class="footer-links">
      <a href={LINKEDIN_URL} target="_blank" rel="noopener" class="footer-link">LinkedIn</a>
      <a href="https://x.com/expatbuildr" target="_blank" rel="noopener" class="footer-link">X</a>
      <a href="/privacy" class="footer-link">Privacy</a>
    </nav>
  </footer>

  <div class="text-me-widget">
    <div class="text-me-panel" id="textMePanel">
      <div class="text-me-title">How can I help you?</div>
      <p class="text-me-sub">Text me directly — no forms, no bots. I'll answer myself.</p>
      <a href={`sms:${TEXT_NUMBER}`} class="text-me-link">💬 {TEXT_NUMBER_DISPLAY}</a>
    </div>
    <button type="button" class="text-me-bubble" id="textMeBubble" aria-label="Text me if you have questions">💬</button>
  </div>

  <script>
    function updateClock() {
      const el = document.getElementById('cebuClock');
      if (!el) return;
      const time = new Date().toLocaleTimeString('en-US', {
        timeZone: 'Asia/Manila', hour: '2-digit', minute: '2-digit'
      });
      el.textContent = `Cebu, PH — ${time} local`;
    }
    updateClock();
    setInterval(updateClock, 30000);

    const toggleBtn = document.getElementById('themeToggle');
    if (toggleBtn) {
      const syncIcon = () => {
        toggleBtn.textContent = document.documentElement.classList.contains('dark') ? '☀️' : '🌙';
      };
      syncIcon();
      toggleBtn.addEventListener('click', () => {
        document.documentElement.classList.toggle('dark');
        const isDark = document.documentElement.classList.contains('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
        syncIcon();
      });
    }

    const textMeBubble = document.getElementById('textMeBubble');
    const textMePanel = document.getElementById('textMePanel');
    if (textMeBubble && textMePanel) {
      textMeBubble.addEventListener('click', () => {
        textMePanel.classList.toggle('open');
      });
      document.addEventListener('click', (e) => {
        if (!textMePanel.contains(e.target) && !textMeBubble.contains(e.target)) {
          textMePanel.classList.remove('open');
        }
      });
    }
  </script>

</body>
</html>
