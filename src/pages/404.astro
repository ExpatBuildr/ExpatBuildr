---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Page Not Found"
  description="The page you're looking for doesn't exist."
  noindex={true}
>
  <section class="story-section" style="text-align:center; min-height: 50vh; display:flex; flex-direction:column; justify-content:center;">
    <div class="section-label" style="margin: 0 auto 24px;">404</div>
    <h2>This page doesn't exist.</h2>
    <p style="margin: 0 auto 40px;">The link might be broken, or the page may have moved.</p>
    <div>
      <a href="/" class="btn-primary">Back to home →</a>
    </div>
  </section>
</Layout>
