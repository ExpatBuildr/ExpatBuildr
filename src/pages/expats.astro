---
import Layout from '../layouts/Layout.astro';
import Pixels from '../components/Pixels.astro';

const title = "Galaxy Arbitrage — For Americans Living Abroad";
const description = "Every week one arbitrage breakdown — geographic, remote work, crypto, AI, attention. The exact math and systems for building a life the office crowd thinks is impossible.";
---

<Layout title={title} description={description} ogImage="/expatog.jpg" minimal={true} noAnimations={true}>
  <Fragment slot="head">
    <Pixels page="newsletter-landing" source="expats" />
    <link href="https://fonts.googleapis.com/css2?family=Epilogue:wght@400;500;700;900&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </Fragment>

  <div class="expats-root">


    <!-- HERO -->
    <section>
      <div class="hero">

        <h1>
          You escaped<br>
          <span class="strike">the commute.</span><br>
          Now escape<br>
          <span class="highlight">the cost.</span>
        </h1>

        <p class="subhead">
          Every week one arbitrage breakdown — geographic, remote work, crypto, AI, attention. The exact math and systems for building a life the office crowd thinks is impossible.
        </p>

        <div class="form-wrap">
          <label class="form-label">Enter your email — it's completely free</label>
          <div class="form-row">
            <input type="email" placeholder="your@email.com" id="hero-email" />
            <button class="btn-primary" id="hero-btn">GET INSTANT ACCESS →</button>
          </div>
          <p id="hero-msg" class="form-msg hidden"></p>
          <div class="form-trust">
            <span>Free forever</span>
            <span>4 resources delivered instantly</span>
            <span>No spam. Ever.</span>
          </div>
        </div>

        <div class="proof-bar">
          <div class="proof-avatars">
            <div>🌏</div><div>🇺🇸</div><div>🇦🇺</div><div>🌎</div>
          </div>
          <div class="proof-text"><strong><span class="sub-count">80</span>+ Freedom Seekers</strong> already inside — expats across Southeast Asia, LATAM, and Europe</div>
        </div>

        <div class="eyebrow" style="margin-top: 40px;">For Americans living outside the US</div>
        <div class="topbar" style="border-radius: 8px; text-align: left;">
          <span>⚡</span> <span class="sub-count">80</span> members strong — free to join, next stop 1000
        </div>
      </div>
    </section>

    <hr class="section-divider">

    <!-- PAIN SECTION -->
    <section class="pain-section">
      <div class="pain-inner">
        <div class="pain-quote">
          "The craziest part is I genuinely used to think this lifestyle was normal."
        </div>
        <div class="pain-attribution">— r/remotework · 847 upvotes</div>

        <p class="pain-bridge">Two days back in the office and they remembered everything. Wake up earlier. Figure out clothes. Sit in traffic. Spend money on gas. Be surrounded by noise. Pretend to be productive while people interrupt every 20 minutes. Then traffic again. <strong>Mentally drained before dinner.</strong></p>

        <p class="pain-bridge">You already figured out the first part — remote work. You bought back your time. But most remote workers stop there. <strong>They're still paying American prices on a remote income.</strong> Austin rent. US taxes. US cost of everything.</p>

        <p class="pain-bridge" style="color: white;">There's a second move. And most people never make it.</p>
      </div>
    </section>

    <!-- MATH SECTION -->
    <section class="math-section">
      <div class="math-inner">
        <div class="section-label">The Math Nobody Shows You</div>
        <h2 class="math-title">Same income. Completely different life.</h2>
        <p class="math-sub">This is what geographic arbitrage actually looks like on paper.</p>

        <div class="math-grid">
          <div class="math-col">
            <div class="math-city">📍 Austin, Texas</div>
            <div class="math-row"><span class="label">Monthly Income</span><span class="val neutral">$8,500</span></div>
            <div class="math-row"><span class="label">Rent + Utils</span><span class="val bad">-$3,200</span></div>
            <div class="math-row"><span class="label">US Taxes</span><span class="val bad">-$1,800</span></div>
            <div class="math-row"><span class="label">Living Expenses</span><span class="val bad">-$1,500</span></div>
            <div class="math-row"><span class="label">Net Savings</span><span class="val bad">$2,000</span></div>
          </div>
          <div class="math-vs">VS</div>
          <div class="math-col winner">
            <div class="math-city">📍 Manila, Philippines</div>
            <div class="math-row"><span class="label">Monthly Income</span><span class="val neutral">$8,500</span></div>
            <div class="math-row"><span class="label">Luxury Condo</span><span class="val good">-$1,200</span></div>
            <div class="math-row"><span class="label">Tax Efficiency</span><span class="val good">-$400</span></div>
            <div class="math-row"><span class="label">Living Expenses</span><span class="val good">-$900</span></div>
            <div class="math-row"><span class="label">Net Savings</span><span class="val good">$6,000</span></div>
          </div>
        </div>

        <div class="math-savings">
          <div class="big">$48,000</div>
          <div class="small">extra saved per year — same income, different country</div>
        </div>
      </div>
    </section>

    <!-- RESOURCES SECTION -->
    <section class="resources-section">
      <div class="resources-inner">
        <div class="section-label">What You Get Instantly — Free</div>
        <h2 class="resources-title">4 resources. Delivered the second you subscribe.</h2>
        <p class="resources-sub">No upsell. No paywall. No waiting. Everything below is yours free.</p>

        <div class="resource-list">
          <div class="resource-item">
            <div class="resource-icon">💼</div>
            <div>
              <div class="resource-name">Remote Jobs Pack</div>
              <p class="resource-desc">50 remote-first companies actively hiring globally — filtered for USD pay and async culture. No US timezone required.</p>
              <div class="resource-tags">
                <span class="resource-tag">50 Companies</span>
                <span class="resource-tag">12 Niches</span>
                <span class="resource-tag">80% Async</span>
              </div>
            </div>
          </div>
          <div class="resource-item">
            <div class="resource-icon">📊</div>
            <div>
              <div class="resource-name">Arbitrage Calculator</div>
              <p class="resource-desc">The Austin vs Manila breakdown. Full cost-of-living math, salary tiers, and your actual FIRE number living abroad.</p>
              <div class="resource-tags">
                <span class="resource-tag">4.75x Cheaper</span>
                <span class="resource-tag">$36k Saved/yr</span>
                <span class="resource-tag">3 Cities</span>
              </div>
            </div>
          </div>
          <div class="resource-item">
            <div class="resource-icon">🤖</div>
            <div>
              <div class="resource-name">Prompt Vault</div>
              <p class="resource-desc">50 battle-tested AI prompts for client acquisition, content, freelance ops, and automation workflows. Zero fluff.</p>
              <div class="resource-tags">
                <span class="resource-tag">50 Prompts</span>
                <span class="resource-tag">6 Categories</span>
                <span class="resource-tag">0 Fluff</span>
              </div>
            </div>
          </div>
          <div class="resource-item">
            <div class="resource-icon">🌏</div>
            <div>
              <div class="resource-name">Geo Arbitrage Starter Kit</div>
              <p class="resource-desc">The exact checklist for moving your income to Southeast Asia — banking, VoIP, payment processors, visa options, and the 48 pitfalls that kill most expat businesses.</p>
              <div class="resource-tags">
                <span class="resource-tag">12 Countries</span>
                <span class="resource-tag">48 Pitfalls</span>
                <span class="resource-tag">2026 Updated</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- AUDIENCE SECTION -->
    <section class="audience-section">
      <div class="audience-inner">
        <div class="section-label">Who This Is For</div>
        <h2 class="audience-title">If any of these sound like you — you're in the right place.</h2>

        <div class="audience-grid">
          <div class="audience-card">
            <div class="audience-emoji">🌏</div>
            <div class="audience-card-title">The Freedom Seeker</div>
            <p class="audience-desc">You suspect you're overpaying for your own life. You want the math that proves it — and the system to fix it.</p>
          </div>
          <div class="audience-card">
            <div class="audience-emoji">💼</div>
            <div class="audience-card-title">The Remote Hustler</div>
            <p class="audience-desc">You have remote income or want it. You need the tools to earn more while working from anywhere on earth.</p>
          </div>
          <div class="audience-card">
            <div class="audience-emoji">⚙️</div>
            <div class="audience-card-title">The Lead Builder</div>
            <p class="audience-desc">You want income systems that run without trading hours for dollars. Automation, attention, and leverage.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- FINAL CTA -->
    <section class="cta-section">
      <div class="cta-inner">
        <h2>You already made the first move.<br>Make the second one.</h2>
        <p>Free. Weekly. The only newsletter built around arbitrage as a complete life and income strategy for people living outside the US.</p>

        <div class="cta-form">
          <input type="email" placeholder="your@email.com" id="cta-email" />
          <button class="btn-primary" id="cta-btn">GET YOUR 4 FREE RESOURCES →</button>
          <p id="cta-msg" class="form-msg hidden"></p>
          <div class="cta-no-spam">✓ Free forever &nbsp;&nbsp; ✓ No spam &nbsp;&nbsp; ✓ Unsubscribe anytime</div>
        </div>
      </div>
    </section>

    <footer>
      <div>© 2026 ExpatBuildr · <a href="https://expatbuildr.com">expatbuildr.com</a> · Galaxy Arbitrage Newsletter</div>
    </footer>

  </div>
</Layout>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  .expats-root {
    --white: #ffffff;
    --off: #f7f7f5;
    --black: #0a0a0a;
    --gray: #6b6b6b;
    --light: #e8e8e4;
    --signal: #ff4d00;
    --signal-hover: #e63d00;
    --border: #e2e2de;
    background: var(--white);
    color: var(--black);
    font-family: 'Epilogue', sans-serif;
    font-size: 18px;
    line-height: 1.6;
  }

  .topbar {
    background: var(--black);
    color: var(--white);
    text-align: center;
    padding: 12px 20px;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 14px;
    letter-spacing: 0.05em;
  }
  .topbar span { color: var(--signal); }

  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 60px 24px 40px;
    max-width: 740px;
    margin: 0 auto;
  }

  .eyebrow {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 13px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--signal);
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .eyebrow::before {
    content: '';
    width: 24px;
    height: 2px;
    background: var(--signal);
    display: inline-block;
  }

  h1 {
    font-size: clamp(48px, 9vw, 80px);
    font-weight: 900;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--black);
    margin-bottom: 28px;
  }
  h1 .strike { text-decoration: line-through; color: #bbb; font-weight: 400; }
  h1 .highlight { color: var(--signal); }

  .subhead {
    font-size: 21px;
    color: #444;
    line-height: 1.6;
    margin-bottom: 40px;
    max-width: 560px;
    font-weight: 400;
  }

  .form-wrap {
    background: var(--off);
    border: 1px solid var(--border);
    padding: 36px;
    margin-bottom: 20px;
  }

  .form-label {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 13px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gray);
    margin-bottom: 12px;
    display: block;
  }

  .form-row { display: flex; gap: 0; }
  @media (max-width: 500px) { .form-row { flex-direction: column; gap: 10px; } }

  input[type="email"] {
    flex: 1;
    padding: 18px 22px;
    font-size: 17px;
    font-family: 'Epilogue', sans-serif;
    border: 2px solid var(--black);
    border-right: none;
    outline: none;
    background: var(--white);
    color: var(--black);
    transition: border-color 0.2s;
  }
  @media (max-width: 500px) { input[type="email"] { border-right: 2px solid var(--black); } }
  input[type="email"]:focus { border-color: var(--signal); }
  input[type="email"]::placeholder { color: #aaa; }

  .btn-primary {
    padding: 18px 32px;
    background: var(--signal);
    color: var(--white);
    font-family: 'Epilogue', sans-serif;
    font-size: 16px;
    font-weight: 700;
    border: 2px solid var(--signal);
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.2s;
    letter-spacing: 0.02em;
  }
  .btn-primary:hover { background: var(--signal-hover); border-color: var(--signal-hover); }
  .btn-primary:disabled { opacity: 0.6; cursor: not-allowed; }

  .form-msg { font-family: 'IBM Plex Mono', monospace; font-size: 13px; color: var(--gray); margin-top: 10px; }
  .form-msg.hidden { display: none; }

  .form-trust {
    font-size: 14px;
    color: var(--gray);
    margin-top: 14px;
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }
  .form-trust span::before { content: '✓ '; color: var(--signal); }

  .proof-bar {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px 0;
    border-top: 1px solid var(--border);
    margin-top: 8px;
  }
  .proof-avatars { display: flex; }
  .proof-avatars div {
    width: 36px; height: 36px; border-radius: 50%;
    border: 2px solid var(--white); background: var(--black);
    margin-left: -8px; display: flex; align-items: center; justify-content: center;
    font-size: 16px;
  }
  .proof-avatars div:first-child { margin-left: 0; }
  .proof-text { font-size: 15px; color: var(--gray); }
  .proof-text strong { color: var(--black); }

  .section-divider { border: none; border-top: 1px solid var(--border); margin: 0; }

  .pain-section { background: var(--black); color: var(--white); padding: 100px 24px; }
  .pain-inner { max-width: 740px; margin: 0 auto; }
  .pain-quote {
    font-size: clamp(26px, 4.5vw, 40px);
    font-weight: 700; line-height: 1.4; letter-spacing: -0.02em;
    margin-bottom: 24px; border-left: 4px solid var(--signal); padding-left: 28px;
  }
  .pain-attribution {
    font-family: 'IBM Plex Mono', monospace; font-size: 13px; color: #666;
    letter-spacing: 0.1em; padding-left: 28px; margin-bottom: 56px;
  }
  .pain-bridge { font-size: 20px; color: #ccc; line-height: 1.75; margin-bottom: 20px; }
  .pain-bridge strong { color: var(--white); }

  .math-section { padding: 100px 24px; background: var(--off); }
  .math-inner { max-width: 740px; margin: 0 auto; }
  .section-label {
    font-family: 'IBM Plex Mono', monospace; font-size: 13px;
    letter-spacing: 0.15em; text-transform: uppercase; color: var(--signal); margin-bottom: 20px;
  }
  .math-title { font-size: clamp(32px, 5vw, 52px); font-weight: 900; letter-spacing: -0.02em; margin-bottom: 12px; line-height: 1.1; color: var(--black); }
  .math-sub { font-size: 18px; color: var(--gray); margin-bottom: 0; }

  .math-grid {
    display: grid; grid-template-columns: 1fr auto 1fr;
    gap: 0; align-items: stretch; margin: 40px 0;
    border: 1px solid var(--border);
  }
  @media (max-width: 500px) {
    .math-grid { grid-template-columns: 1fr; }
    .math-vs { padding: 14px; border-left: none; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
  }

  .math-col { padding: 36px 32px; background: var(--white); }
  .math-col.winner { background: #f0fff4; border-left: 3px solid #22c55e; }
  .math-vs {
    display: flex; align-items: center; justify-content: center;
    padding: 0 22px; background: var(--black); color: var(--white);
    font-family: 'IBM Plex Mono', monospace; font-size: 15px; font-weight: 500;
    border-left: 1px solid var(--border); border-right: 1px solid var(--border);
  }
  .math-city { font-family: 'IBM Plex Mono', monospace; font-size: 13px; letter-spacing: 0.1em; color: var(--gray); margin-bottom: 20px; text-transform: uppercase; }
  .math-row { display: flex; justify-content: space-between; align-items: center; padding: 12px 0; border-bottom: 1px solid var(--border); font-size: 16px; }
  .math-row:last-child { border-bottom: none; }
  .math-row .label { color: var(--gray); }
  .math-row .val { font-weight: 700; font-family: 'IBM Plex Mono', monospace; font-size: 15px; }
  .math-row .val.bad { color: #ef4444; }
  .math-row .val.good { color: #22c55e; }
  .math-row .val.neutral { color: var(--black); }

  .math-savings { margin-top: 20px; padding: 24px; background: var(--black); color: var(--white); text-align: center; }
  .math-savings .big { font-size: 56px; font-weight: 900; color: #22c55e; letter-spacing: -0.03em; font-family: 'Epilogue', sans-serif; }
  .math-savings .small { font-size: 15px; color: #888; font-family: 'IBM Plex Mono', monospace; letter-spacing: 0.08em; margin-top: 6px; }

  .resources-section { padding: 100px 24px; background: var(--white); }
  .resources-inner { max-width: 740px; margin: 0 auto; }
  .resources-title { font-size: clamp(32px, 5vw, 52px); font-weight: 900; letter-spacing: -0.02em; margin-bottom: 12px; line-height: 1.1; color: var(--black); }
  .resources-sub { font-size: 18px; color: var(--gray); margin-bottom: 0; }

  .resource-list { display: flex; flex-direction: column; gap: 3px; margin: 36px 0; }
  .resource-item {
    display: flex; align-items: flex-start; gap: 24px; padding: 28px;
    background: var(--off); border-left: 3px solid transparent; transition: border-color 0.2s;
  }
  .resource-item:hover { border-color: var(--signal); }
  .resource-icon { font-size: 34px; flex-shrink: 0; margin-top: 2px; }
  .resource-name { font-size: 18px; font-weight: 700; color: var(--black); margin-bottom: 6px; }
  .resource-desc { font-size: 15px; color: var(--gray); line-height: 1.6; margin: 0; }
  .resource-tags { display: flex; gap: 8px; margin-top: 10px; flex-wrap: wrap; }
  .resource-tag {
    font-family: 'IBM Plex Mono', monospace; font-size: 11px; padding: 4px 10px;
    background: var(--white); border: 1px solid var(--border); color: var(--gray); letter-spacing: 0.05em;
  }

  .audience-section { padding: 100px 24px; background: var(--off); }
  .audience-inner { max-width: 740px; margin: 0 auto; }
  .audience-title { font-size: clamp(32px, 5vw, 52px); font-weight: 900; letter-spacing: -0.02em; margin-bottom: 36px; line-height: 1.1; color: var(--black); }

  .audience-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 3px; margin: 36px 0; }
  @media (max-width: 600px) { .audience-grid { grid-template-columns: 1fr; } }

  .audience-card { background: var(--white); padding: 28px 24px; border-top: 3px solid var(--border); transition: border-color 0.2s; }
  .audience-card:hover { border-color: var(--signal); }
  .audience-emoji { font-size: 30px; margin-bottom: 14px; }
  .audience-card-title { font-size: 17px; font-weight: 700; color: var(--black); margin-bottom: 10px; }
  .audience-desc { font-size: 14px; color: var(--gray); line-height: 1.6; margin: 0; }

  .cta-section { padding: 100px 24px 120px; background: var(--white); text-align: center; }
  .cta-inner { max-width: 600px; margin: 0 auto; }
  .cta-section h2 { font-size: clamp(32px, 5.5vw, 56px); font-weight: 900; letter-spacing: -0.03em; line-height: 1.1; margin-bottom: 20px; color: var(--black); }
  .cta-section p { font-size: 18px; color: var(--gray); margin-bottom: 40px; line-height: 1.6; }

  .cta-form { display: flex; flex-direction: column; gap: 12px; max-width: 480px; margin: 0 auto; }
  .cta-form input[type="email"] { border-right: 2px solid var(--black); width: 100%; text-align: center; }
  .cta-form .btn-primary { width: 100%; font-size: 17px; padding: 20px; letter-spacing: 0.03em; }
  .cta-no-spam { font-size: 13px; color: #aaa; margin-top: 10px; font-family: 'IBM Plex Mono', monospace; }

  footer { background: var(--black); color: #555; text-align: center; padding: 28px; font-family: 'IBM Plex Mono', monospace; font-size: 13px; letter-spacing: 0.05em; }
  footer a { color: #666; text-decoration: none; }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .hero > * { opacity: 0; animation: fadeUp 0.5s ease forwards; }
  .hero > *:nth-child(1) { animation-delay: 0.1s; }
  .hero > *:nth-child(2) { animation-delay: 0.2s; }
  .hero > *:nth-child(3) { animation-delay: 0.3s; }
  .hero > *:nth-child(4) { animation-delay: 0.4s; }
  .hero > *:nth-child(5) { animation-delay: 0.5s; }
</style>

<script is:inline>
  async function submitEmail(inputId, btnId, msgId) {
    const emailEl = document.getElementById(inputId);
    const btnEl = document.getElementById(btnId);
    const msgEl = document.getElementById(msgId);
    const email = emailEl.value.trim();

    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRegex.test(email)) {
      emailEl.style.borderColor = '#ff4d00';
      emailEl.focus();
      return;
    }

    btnEl.disabled = true;
    btnEl.textContent = 'Joining...';
    msgEl.classList.add('hidden');

    try {
      const res = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, source: 'expats', magnet: 'geo-arbitrage-starter-kit', tags: ['freedom-seekers'] })
      });
      const data = await res.json();
      if (data.success) {
        if (window.fireLeadEvent) window.fireLeadEvent();
        btnEl.textContent = 'Redirecting...';
        window.location.href = '/expats-thankyou';
      } else {
        btnEl.disabled = false;
        btnEl.textContent = 'GET INSTANT ACCESS →';
        msgEl.textContent = '❌ ' + (data.error || 'Something went wrong. Try again.');
        msgEl.classList.remove('hidden');
      }
    } catch (err) {
      btnEl.disabled = false;
      btnEl.textContent = 'GET INSTANT ACCESS →';
      msgEl.textContent = '❌ Network error. Please try again.';
      msgEl.classList.remove('hidden');
    }
  }

  document.getElementById('hero-btn').addEventListener('click', () => submitEmail('hero-email', 'hero-btn', 'hero-msg'));
  document.getElementById('cta-btn').addEventListener('click', () => submitEmail('cta-email', 'cta-btn', 'cta-msg'));

  document.getElementById('hero-email').addEventListener('keydown', (e) => { if (e.key === 'Enter') submitEmail('hero-email', 'hero-btn', 'hero-msg'); });
  document.getElementById('cta-email').addEventListener('keydown', (e) => { if (e.key === 'Enter') submitEmail('cta-email', 'cta-btn', 'cta-msg'); });

  fetch('/get-counter')
    .then(r => r.json())
    .then(d => {
      const elements = document.querySelectorAll('.sub-count');
      elements.forEach(el => el.textContent = d.count.toLocaleString());
    })
    .catch(err => console.error('Failed to load subscriber count', err));
</script>
